local notifCount = 0

function ModernUI:Notify(data)
    notifCount += 1
    local myOrder = notifCount

    task.spawn(function()
        local typeColors = {
            Success = SelectedTheme.Success,
            Error   = SelectedTheme.Error,
            Warning = SelectedTheme.Warning,
            Info    = SelectedTheme.Info,
        }
        local accentColor = data.AccentColor
            or typeColors[data.Type]
            or SelectedTheme.Accent

        -- Wrapper for animation
        local wrapper = Instance.new("Frame")
        wrapper.Name             = "NotifWrapper"
        wrapper.Size             = UDim2.new(1, 0, 0, 0)
        wrapper.BackgroundTransparency = 1
        wrapper.ClipsDescendants = true
        wrapper.LayoutOrder      = myOrder
        wrapper.Parent           = NotifContainer

        local notif = Instance.new("Frame")
        notif.Name               = "Notification"
        notif.Size               = UDim2.new(1, 0, 1, 0)
        notif.BackgroundColor3   = SelectedTheme.NotifBg
        notif.BackgroundTransparency = 1
        notif.Parent             = wrapper
        makeRound(notif, 12)
        local stroke = makeStroke(notif, accentColor, 1, 0.6)

        -- Accent left bar
        local bar = Instance.new("Frame")
        bar.Size            = UDim2.new(0, 3, 0.7, 0)
        bar.Position        = UDim2.new(0, 0, 0.15, 0)
        bar.BackgroundColor3 = accentColor
        bar.BorderSizePixel = 0
        bar.Parent          = notif
        makeRound(bar, 4)

        -- Progress bar (duration indicator)
        local progressBg = Instance.new("Frame")
        progressBg.Size            = UDim2.new(1, -16, 0, 2)
        progressBg.Position        = UDim2.new(0, 8, 1, -6)
        progressBg.BackgroundColor3 = SelectedTheme.Border
        progressBg.BorderSizePixel = 0
        progressBg.Parent          = notif
        makeRound(progressBg, 1)

        local progressFill = Instance.new("Frame")
        progressFill.Size            = UDim2.new(1, 0, 1, 0)
        progressFill.BackgroundColor3 = accentColor
        progressFill.BorderSizePixel = 0
        progressFill.Parent          = progressBg
        makeRound(progressFill, 1)

        -- Icon (type-based)
        local typeIcons = {
            Success = "✓", Error = "✕", Warning = "⚠", Info = "ℹ"
        }
        local iconFrame = Instance.new("Frame")
        iconFrame.Size            = UDim2.new(0, 32, 0, 32)
        iconFrame.Position        = UDim2.new(0, 14, 0.5, -16)
        iconFrame.BackgroundColor3 = accentColor:Lerp(SelectedTheme.NotifBg, 0.75)
        iconFrame.BorderSizePixel = 0
        iconFrame.Parent          = notif
        makeRound(iconFrame, 8)

        local iconLbl = Instance.new("TextLabel")
        iconLbl.Size               = UDim2.new(1, 0, 1, 0)
        iconLbl.BackgroundTransparency = 1
        iconLbl.Text               = data.Image and "" or (typeIcons[data.Type] or "◆")
        iconLbl.TextColor3         = accentColor
        iconLbl.Font               = Enum.Font.GothamBold
        iconLbl.TextSize           = 14
        iconLbl.Parent             = iconFrame

        if data.Image then
            local img = Instance.new("ImageLabel")
            img.Size               = UDim2.new(1, -8, 1, -8)
            img.Position           = UDim2.new(0, 4, 0, 4)
            img.BackgroundTransparency = 1
            img.Image              = "rbxassetid://" .. tostring(data.Image)
            img.ImageColor3        = accentColor
            img.ScaleType          = Enum.ScaleType.Fit
            img.Parent             = iconFrame
        end

        -- Title
        local titleLbl = Instance.new("TextLabel")
        titleLbl.Size              = UDim2.new(1, -70, 0, 18)
        titleLbl.Position          = UDim2.new(0, 56, 0, 12)
        titleLbl.BackgroundTransparency = 1
        titleLbl.Text              = data.Title or "Notification"
        titleLbl.TextColor3        = SelectedTheme.TextPrimary
        titleLbl.TextTransparency  = 1
        titleLbl.Font              = Enum.Font.GothamBold
        titleLbl.TextSize          = 13
        titleLbl.TextXAlignment    = Enum.TextXAlignment.Left
        titleLbl.Parent            = notif

        -- Content
        local contentLbl = Instance.new("TextLabel")
        contentLbl.Size              = UDim2.new(1, -70, 0, 0)
        contentLbl.Position          = UDim2.new(0, 56, 0, 32)
        contentLbl.BackgroundTransparency = 1
        contentLbl.Text              = data.Content or ""
        contentLbl.TextColor3        = SelectedTheme.TextSecondary
        contentLbl.TextTransparency  = 1
        contentLbl.Font              = Enum.Font.Gotham
        contentLbl.TextSize          = 12
        contentLbl.TextXAlignment    = Enum.TextXAlignment.Left
        contentLbl.TextWrapped       = true
        contentLbl.AutomaticSize     = Enum.AutomaticSize.Y
        contentLbl.Parent            = notif

        -- Close button
        local closeBtn = Instance.new("TextButton")
        closeBtn.Size              = UDim2.new(0, 20, 0, 20)
        closeBtn.Position          = UDim2.new(1, -26, 0, 6)
        closeBtn.BackgroundTransparency = 1
        closeBtn.Text              = "×"
        closeBtn.TextColor3        = SelectedTheme.TextMuted
        closeBtn.Font              = Enum.Font.GothamBold
        closeBtn.TextSize          = 16
        closeBtn.ZIndex            = 5
        closeBtn.Parent            = notif

        task.wait(0.05)

        local textH  = contentLbl.TextBounds.Y
        local totalH = math.max(textH + 60, 75)

        -- Slide in
        tween(wrapper, spring(0.5), {Size = UDim2.new(1, 0, 0, totalH + 8)})
        tween(notif, spring(0.5), {BackgroundTransparency = 0.05})
        task.wait(0.15)
        tween(titleLbl, ease(0.4), {TextTransparency = 0})
        tween(contentLbl, ease(0.4), {TextTransparency = 0.1})

        local duration = data.Duration
            or math.clamp(#(data.Content or "") * 0.055 + 3.5, 3.5, 12)

        -- Progress shrink
        tween(progressFill, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 1, 0)
        })

        local dismissed = false
        local function dismiss()
            if dismissed then return end
            dismissed = true
            tween(notif, ease(0.35), {BackgroundTransparency = 1})
            tween(titleLbl, ease(0.25), {TextTransparency = 1})
            tween(contentLbl, ease(0.25), {TextTransparency = 1})
            tween(wrapper, spring(0.45), {Size = UDim2.new(1, 0, 0, 0)})
            task.wait(0.5)
            wrapper:Destroy()
        end

        closeBtn.MouseButton1Click:Connect(dismiss)
        task.wait(duration)
        dismiss()
    end)
end

