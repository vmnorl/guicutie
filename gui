local function saveConfig()
    if not CEnabled or not globalLoaded then return end
    local data = {}
    for flag, element in pairs(ModernUI.Flags) do
        local t = element.Type
        if t == "ColorPicker" then
            local c = element.CurrentColor
            if c then data[flag] = {R=round(c.R*255), G=round(c.G*255), B=round(c.B*255)} end
        elseif t == "Toggle" then
            data[flag] = element.CurrentValue
        elseif t == "Slider" then
            data[flag] = element.CurrentValue
        elseif t == "Dropdown" then
            data[flag] = element.CurrentOption
        elseif t == "Keybind" then
            data[flag] = element.CurrentKeybind
        elseif t == "Input" then
            data[flag] = element.CurrentValue
        end
    end
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then
        pcall(writefile, ConfigFolder .. "/" .. CFileName .. ConfigExt, encoded)
    end
end

local function loadConfig()
    if not CEnabled then return end
    if not (isfile and isfile(ConfigFolder .. "/" .. CFileName .. ConfigExt)) then return end
    local raw = readfile(ConfigFolder .. "/" .. CFileName .. ConfigExt)
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok or type(data) ~= "table" then return end
    for flag, value in pairs(data) do
        local el = ModernUI.Flags[flag]
        if el and el.Set then
            task.spawn(function()
                pcall(function()
                    if el.Type == "ColorPicker" then
                        el:Set(Color3.fromRGB(value.R, value.G, value.B))
                    else
                        el:Set(value)
                    end
                end)
            end)
        end
    end
end

