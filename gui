            divider.BackgroundColor3 = SelectedTheme.Border
            divider.BorderSizePixel = 0
            divider.LayoutOrder     = 0
            divider.Parent          = optFrame

            local optBtns = {}

            local function refreshLabel()
                if #settings.CurrentOption == 0 then
                    selLbl.Text = "None"
                elseif #settings.CurrentOption == 1 then
                    selLbl.Text = settings.CurrentOption[1]
                else
                    selLbl.Text = tostring(#settings.CurrentOption) .. " selected"
                end
