        -- ══════════════════════════════════════════════════════
        function Tab:CreateToggle(settings)
            assert(type(settings) == "table", "[ModernUI] CreateToggle expects a table")
            settings.Type         = "Toggle"
            settings.CurrentValue = settings.CurrentValue or false

            local height = settings.Description and 60 or 52
            local card   = makeCard(height)

            local nameLbl = Instance.new("TextLabel")
            nameLbl.Size             = UDim2.new(1, -80, settings.Description and 0 or 1, settings.Description and 22 or 0)
            nameLbl.Position         = UDim2.new(0, 14, 0, settings.Description and 9 or 0)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text             = settings.Name or "Toggle"
            nameLbl.TextColor3       = SelectedTheme.TextPrimary
            nameLbl.Font             = Enum.Font.GothamSemibold
            nameLbl.TextSize         = 13
            nameLbl.TextXAlignment   = Enum.TextXAlignment.Left
            nameLbl.Parent           = card

            if settings.Description then
                local descLbl = Instance.new("TextLabel")
                descLbl.Size             = UDim2.new(1, -80, 0, 14)
                descLbl.Position         = UDim2.new(0, 14, 0, 34)
                descLbl.BackgroundTransparency = 1
                descLbl.Text             = settings.Description
                descLbl.TextColor3       = SelectedTheme.TextMuted
                descLbl.Font             = Enum.Font.Gotham
                descLbl.TextSize         = 11
                descLbl.TextXAlignment   = Enum.TextXAlignment.Left
                descLbl.Parent           = card
            end

            -- Track
            local track = Instance.new("Frame")
            track.Size            = UDim2.new(0, 46, 0, 26)
            track.Position        = UDim2.new(1, -60, 0.5, -13)
            track.BackgroundColor3 = settings.CurrentValue
                and SelectedTheme.ToggleOn
                or  SelectedTheme.ToggleOff
            track.BorderSizePixel = 0
            track.ZIndex          = 4
            track.Parent          = card
            makeRound(track, 13)
            makeStroke(track, SelectedTheme.Border, 1, 0)

            -- Knob
            local knob = Instance.new("Frame")
            knob.Size            = UDim2.new(0, 20, 0, 20)
            knob.Position        = settings.CurrentValue
                and UDim2.new(1, -23, 0.5, -10)
                or  UDim2.new(0, 3, 0.5, -10)
            knob.BackgroundColor3 = SelectedTheme.ToggleKnob
            knob.BorderSizePixel = 0
            knob.ZIndex          = 5
            knob.Parent          = track
            makeRound(knob, 10)
            makeShadow(knob)

            local ghost = Instance.new("TextButton")
            ghost.Size               = UDim2.new(1, 0, 1, 0)
            ghost.BackgroundTransparency = 1
            ghost.Text               = ""
            ghost.ZIndex             = 6
            ghost.Parent             = card

            local function applyToggle(val, silent)
                settings.CurrentValue = val
                if val then
                    tween(track, spring(0.4), {BackgroundColor3 = SelectedTheme.ToggleOn})
                    tween(knob, spring(0.5), {Position = UDim2.new(1, -23, 0.5, -10)})
                else
                    tween(track, spring(0.4), {BackgroundColor3 = SelectedTheme.ToggleOff})
                    tween(knob, spring(0.5), {Position = UDim2.new(0, 3, 0.5, -10)})
                end
                if not silent then
                    safecall(settings.Callback, val)
                    saveConfig()
                end
            end

            ghost.MouseButton1Click:Connect(function()
                applyToggle(not settings.CurrentValue)
            end)

            if settings.Tooltip then makeTooltip(card, settings.Tooltip) end

            function settings:Set(v) applyToggle(v, false) end

            if settings.Flag and CEnabled then
                ModernUI.Flags[settings.Flag] = settings
            end

            -- Apply initial silently (no callback, no save)
            applyToggle(settings.CurrentValue, true)

            return settings
        end

