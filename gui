    ContentArea.Size             = UDim2.new(1, -164, 1, -68)
    ContentArea.Position         = UDim2.new(0, 158, 0, 62)
    ContentArea.BackgroundTransparency = 1
    ContentArea.ZIndex           = 2
    ContentArea.ClipsDescendants = true
    ContentArea.Parent           = Window

    -- ── State ─────────────────────────────────────────────────
    local currentPage   = nil
    local currentTabBtn = nil
    local isMinimised   = false
    local isMaximised   = false
    local normalSize    = UDim2.new(0, 600, 0, 540)
    local minimisedSize = UDim2.new(0, 600, 0, 54)

    -- ── Draggable ─────────────────────────────────────────────
    makeDraggable(Window, Topbar)

    -- ── Minimize ──────────────────────────────────────────────
    MinBtn.MouseButton1Click:Connect(function()
        if Debounce then return end
        Debounce = true
        if isMinimised then
            isMinimised = false
            tween(Window, spring(0.55), {Size = normalSize})
            task.wait(0.1)
            ContentArea.Visible = true
            Sidebar.Visible     = true
        else
            isMinimised = true
            ContentArea.Visible = false
            Sidebar.Visible     = false
            tween(Window, spring(0.55), {Size = minimisedSize})
        end
        task.wait(0.6)
        Debounce = false
    end)

    -- ── Maximise ─────────────────────────────────────────────
    MaxBtn.MouseButton1Click:Connect(function()
        if Debounce then return end
        Debounce = true
        if isMaximised then
            isMaximised = false
            tween(Window, spring(0.55), {Size = normalSize, Position = UDim2.new(0.5, -300, 0.5, -270)})
        else
            isMaximised = true
            tween(Window, spring(0.55), {Size = UDim2.new(0, 780, 0, 600), Position = UDim2.new(0.5, -390, 0.5, -300)})
        end
        task.wait(0.6)
        Debounce = false
    end)

    -- ── Close ─────────────────────────────────────────────────
    CloseBtn.MouseButton1Click:Connect(function()
        tween(Window, ease(0.4), {BackgroundTransparency = 1, Size = UDim2.new(0, 580, 0, 0)})
        task.wait(0.45)
        ModernUI:Destroy()
    end)

    -- ── Toggle Hotkey ─────────────────────────────────────────
    local hotkey = UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        local ok, kc = pcall(function() return Enum.KeyCode[openKeybind] end)
        if not ok then return end
        if input.KeyCode == kc then
            if Hidden then
                Hidden       = false
                Window.Visible = true
                tween(Window, spring(0.5), {BackgroundTransparency = 0})
            else
                Hidden = true
                tween(Window, ease(0.35), {BackgroundTransparency = 1})
                task.delay(0.4, function()
                    if Hidden then Window.Visible = false end
                end)
            end
        end
    end)
    table.insert(keybindConns, hotkey)

    -- ═══════════════════════════════════════════════════════════
    -- WINDOW OBJECT
    -- ═══════════════════════════════════════════════════════════
    local WindowObj    = {}
    local tabOrder     = 0

    -- ── Create Tab ────────────────────────────────────────────
    function WindowObj:CreateTab(name, icon)
        assert(type(name) == "string", "[ModernUI] Tab name must be a string")
        tabOrder += 1

        -- ── Tab Button ────────────────────────────────────────
        local TabBtn = Instance.new("TextButton")
        TabBtn.Name              = "Tab_" .. name
        TabBtn.Size              = UDim2.new(1, 0, 0, 40)
        TabBtn.BackgroundColor3  = SelectedTheme.TabInactive
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text              = ""
        TabBtn.BorderSizePixel   = 0
        TabBtn.ZIndex            = 4
        TabBtn.AutoButtonColor   = false
        TabBtn.LayoutOrder       = tabOrder
        TabBtn.Parent            = TabList
        makeRound(TabBtn, 10)

        -- Active indicator bar
        local indicator = Instance.new("Frame")
        indicator.Name            = "Indicator"
        indicator.Size            = UDim2.new(0, 3, 0.55, 0)
        indicator.Position        = UDim2.new(0, 0, 0.225, 0)
        indicator.BackgroundColor3 = SelectedTheme.TabActive
        indicator.BackgroundTransparency = 1
        indicator.BorderSizePixel = 0
        indicator.ZIndex          = 5
        indicator.Parent          = TabBtn
        makeRound(indicator, 2)

        -- Icon
        local TabIcon = Instance.new("ImageLabel")
        TabIcon.Size               = UDim2.new(0, 18, 0, 18)
        TabIcon.Position           = UDim2.new(0, 14, 0.5, -9)
        TabIcon.BackgroundTransparency = 1
        TabIcon.Image              = icon and ("rbxassetid://" .. tostring(icon)) or ""
        TabIcon.ImageColor3        = SelectedTheme.TabText
        TabIcon.ScaleType          = Enum.ScaleType.Fit
        TabIcon.ZIndex             = 5
        TabIcon.Parent             = TabBtn

        -- Label
        local TabLabel = Instance.new("TextLabel")
        TabLabel.Size              = UDim2.new(1, icon and -40 or -18, 1, 0)
        TabLabel.Position          = UDim2.new(0, icon and 38 or 12, 0, 0)
        TabLabel.BackgroundTransparency = 1
        TabLabel.Text              = name
        TabLabel.TextColor3        = SelectedTheme.TabText
        TabLabel.Font              = Enum.Font.GothamSemibold
        TabLabel.TextSize          = 13
        TabLabel.TextXAlignment    = Enum.TextXAlignment.Left
        TabLabel.ZIndex            = 5
        TabLabel.Parent            = TabBtn

        -- ── Page (scrolling) ──────────────────────────────────
        local Page = Instance.new("ScrollingFrame")
        Page.Name                 = "Page_" .. name
        Page.Size                 = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.BorderSizePixel      = 0
        Page.ScrollBarThickness   = 3
        Page.ScrollBarImageColor3 = SelectedTheme.Scrollbar
        Page.ScrollBarImageTransparency = 0.4
        Page.CanvasSize           = UDim2.new(0, 0, 0, 0)
        Page.AutomaticCanvasSize  = Enum.AutomaticSize.Y
        Page.Visible              = false
        Page.ZIndex               = 3
        Page.Parent               = ContentArea

        local PageLayout = Instance.new("UIListLayout")
        PageLayout.Parent   = Page
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        PageLayout.Padding  = UDim.new(0, 6)

        local PagePad = Instance.new("UIPadding")
        PagePad.Parent       = Page
        PagePad.PaddingTop    = UDim.new(0, 4)
        PagePad.PaddingBottom = UDim.new(0, 10)
        PagePad.PaddingRight  = UDim.new(0, 4)
        PagePad.PaddingLeft   = UDim.new(0, 2)

        -- Activate first tab automatically
        if currentPage == nil then
            currentPage   = Page
            currentTabBtn = TabBtn
            Page.Visible  = true
            TabBtn.BackgroundTransparency = 0
            TabLabel.TextColor3  = SelectedTheme.TabActiveText
            TabIcon.ImageColor3  = SelectedTheme.TabActiveText
            tween(indicator, spring(0.3), {BackgroundTransparency = 0})
        end

        -- ── Tab Selection Logic ───────────────────────────────
        local function activateTab()
            if currentPage == Page then return end

            -- Deactivate old
            if currentPage then
                local oldPage = currentPage
                tween(oldPage, ease(0.2), {})
                oldPage.Visible = false
            end
            if currentTabBtn then
                local old = currentTabBtn
                tween(old, ease(0.25), {
                    BackgroundTransparency = 1,
                    BackgroundColor3 = SelectedTheme.TabInactive
                })
                local oldInd = old:FindFirstChild("Indicator")
                if oldInd then
                    tween(oldInd, ease(0.25), {BackgroundTransparency = 1})
                end
                for _, c in ipairs(old:GetChildren()) do
                    if c:IsA("TextLabel") then
                        tween(c, ease(0.25), {TextColor3 = SelectedTheme.TabText})
                    elseif c:IsA("ImageLabel") then
                        tween(c, ease(0.25), {ImageColor3 = SelectedTheme.TabText})
                    end
                end
            end

            -- Activate new
            currentPage   = Page
            currentTabBtn = TabBtn
            Page.Visible  = true

            tween(TabBtn, ease(0.25), {
                BackgroundTransparency = 0,
                BackgroundColor3 = SelectedTheme.TabInactive
            })
            tween(TabLabel, ease(0.25), {TextColor3 = SelectedTheme.TabActiveText})
            tween(TabIcon,  ease(0.25), {ImageColor3 = SelectedTheme.TabActiveText})
            tween(indicator, spring(0.3), {BackgroundTransparency = 0})
        end

        TabBtn.MouseButton1Click:Connect(activateTab)

        TabBtn.MouseEnter:Connect(function()
            if currentTabBtn ~= TabBtn then
                tween(TabBtn, ease(0.2), {BackgroundTransparency = 0.82})
            end
        end)
        TabBtn.MouseLeave:Connect(function()
            if currentTabBtn ~= TabBtn then
                tween(TabBtn, ease(0.2), {BackgroundTransparency = 1})
            end
        end)

        -- ═══════════════════════════════════════════════════════
        -- TAB OBJECT + ELEMENT API
        -- ═══════════════════════════════════════════════════════
        local Tab = {}
        local elementOrder = 0

        local function nextOrder()
            elementOrder += 1
            return elementOrder
        end

        -- ── Card factory (base for all elements) ──────────────
        local function makeCard(height, noHover)
            local card = Instance.new("Frame")
            card.Size            = UDim2.new(1, 0, 0, height or 52)
            card.BackgroundColor3 = SelectedTheme.Surface
            card.BorderSizePixel = 0
            card.LayoutOrder     = nextOrder()
            card.ClipsDescendants = false
            card.Parent          = Page
            makeRound(card, 10)
            makeStroke(card, SelectedTheme.Border, 1, 0)

            if not noHover then
                card.MouseEnter:Connect(function()
                    tween(card, ease(0.25), {BackgroundColor3 = SelectedTheme.SurfaceHover})
                end)
                card.MouseLeave:Connect(function()
                    tween(card, ease(0.25), {BackgroundColor3 = SelectedTheme.Surface})
                end)
            end
            return card
        end

        -- ── Ripple effect ─────────────────────────────────────
        local function addRipple(btn, color)
            btn.MouseButton1Down:Connect(function(x, y)
                local rip = Instance.new("Frame")
                rip.Size               = UDim2.new(0, 0, 0, 0)
                rip.Position           = UDim2.new(0, x - btn.AbsolutePosition.X, 0, y - btn.AbsolutePosition.Y)
                rip.AnchorPoint        = Vector2.new(0.5, 0.5)
                rip.BackgroundColor3   = color or Color3.fromRGB(255, 255, 255)
                rip.BackgroundTransparency = 0.85
                rip.BorderSizePixel    = 0
                rip.ZIndex             = btn.ZIndex + 1
                rip.Parent             = btn
                makeRound(rip, 100)

                local maxS = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 2.5
                tween(rip, ease(0.5), {
                    Size = UDim2.new(0, maxS, 0, maxS),
                    BackgroundTransparency = 1,
                })
                task.delay(0.5, function() rip:Destroy() end)
            end)
        end

        -- ══════════════════════════════════════════════════════
        -- SECTION
        -- ══════════════════════════════════════════════════════
        function Tab:CreateSection(sectionName)
            local frame = Instance.new("Frame")
