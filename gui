                end)
                card.MouseLeave:Connect(function()
                    tween(card, ease(0.25), {BackgroundColor3 = SelectedTheme.Surface})
                end)
            end
            return card
        end

        local function addRipple(btn)
            btn.MouseButton1Down:Connect(function(x, y)
                local rip = Instance.new("Frame")
                rip.Size               = UDim2.new(0,0,0,0)
                rip.Position           = UDim2.new(0, x - btn.AbsolutePosition.X, 0, y - btn.AbsolutePosition.Y)
                rip.AnchorPoint        = Vector2.new(0.5,0.5)
                rip.BackgroundColor3   = Color3.fromRGB(255,255,255)
                rip.BackgroundTransparency = 0.82
                rip.BorderSizePixel    = 0
                rip.ZIndex             = btn.ZIndex + 1
                rip.Parent             = btn
                makeRound(rip, 100)
                local maxS = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 2.5
                tween(rip, ease(0.5), {
                    Size = UDim2.new(0,maxS,0,maxS),
                    BackgroundTransparency = 1
                })
                task.delay(0.5, function() pcall(function() rip:Destroy() end) end)
            end)
        end

