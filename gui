            refreshLabel()

            local totalOptH = 1 -- divider
            for _, opt in ipairs(settings.Options or {}) do
                local isSelected = table.find(settings.CurrentOption, opt) ~= nil

                local btn = Instance.new("TextButton")
                btn.Size            = UDim2.new(1, 0, 0, ITEM_H - 4)
                btn.BackgroundColor3 = isSelected
                    and SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.72)
                    or  SelectedTheme.Surface
