-- Utilities
local function tween(obj, info, props)
    return TweenService:Create(obj, info, props):Play()
end

local function spring(t)
    return TweenInfo.new(t or 0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
end

local function ease(t)
    return TweenInfo.new(t or 0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
end

local function safecall(f, ...)
    if f then
        local ok, err = pcall(f, ...)
        if not ok then warn("ModernUI | Error: " .. tostring(err)) end
        return ok, err
    end
end

local function ensureFolder(path)
    if isfolder and not isfolder(path) then
        makefolder(path)
    end
end

