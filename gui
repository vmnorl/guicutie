        function Tab:CreateDropdown(settings)
            settings.Type = "Dropdown"
            if type(settings.CurrentOption) == "string" then
                settings.CurrentOption = {settings.CurrentOption}
            end
            settings.CurrentOption = settings.CurrentOption or {}

            local isOpen = false
            local ITEM_H = 36
            local card = makeCard(50)
            card.ClipsDescendants = true
            card.ZIndex = 10

            local titleLbl = Instance.new("TextLabel")
            titleLbl.Size = UDim2.new(0.5, 0, 0, 50)
            titleLbl.Position = UDim2.new(0, 14, 0, 0)
            titleLbl.BackgroundTransparency = 1
            titleLbl.Text = settings.Name or "Dropdown"
            titleLbl.TextColor3 = SelectedTheme.TextPrimary
            titleLbl.Font = Enum.Font.GothamSemibold
            titleLbl.TextSize = 13
            titleLbl.TextXAlignment = Enum.TextXAlignment.Left
            titleLbl.Parent = card

            local selectedLbl = Instance.new("TextLabel")
            selectedLbl.Size = UDim2.new(0.45, -40, 0, 50)
            selectedLbl.Position = UDim2.new(0.5, 0, 0, 0)
            selectedLbl.BackgroundTransparency = 1
            selectedLbl.Text = #settings.CurrentOption > 0 and table.concat(settings.CurrentOption, ", ") or "None"
            selectedLbl.TextColor3 = SelectedTheme.Accent
            selectedLbl.Font = Enum.Font.GothamSemibold
            selectedLbl.TextSize = 12
            selectedLbl.TextXAlignment = Enum.TextXAlignment.Right
            selectedLbl.Parent = card

            -- Arrow
            local arrow = Instance.new("TextLabel")
            arrow.Size = UDim2.new(0, 20, 0, 20)
            arrow.Position = UDim2.new(1, -30, 0, 15)
            arrow.BackgroundTransparency = 1
            arrow.Text = "▾"
            arrow.TextColor3 = SelectedTheme.TextMuted
            arrow.Font = Enum.Font.GothamBold
            arrow.TextSize = 14
            arrow.Parent = card

            -- Options list
            local optList = Instance.new("Frame")
            optList.Size = UDim2.new(1, -28, 0, 0)
            optList.Position = UDim2.new(0, 14, 0, 50)
            optList.BackgroundTransparency = 1
            optList.ZIndex = 11
            optList.Parent = card

            local optLayout = Instance.new("UIListLayout")
            optLayout.Parent = optList
            optLayout.SortOrder = Enum.SortOrder.LayoutOrder
            optLayout.Padding = UDim.new(0, 4)

            -- Divider
            local divider = Instance.new("Frame")
            divider.Size = UDim2.new(1, 0, 0, 1)
            divider.Position = UDim2.new(0, 0, 0, 0)
            divider.BackgroundColor3 = SelectedTheme.Border
            divider.BorderSizePixel = 0
            divider.Parent = optList

            local function refreshSelected()
                if #settings.CurrentOption == 0 then
                    selectedLbl.Text = "None"
                elseif #settings.CurrentOption == 1 then
                    selectedLbl.Text = settings.CurrentOption[1]
                else
                    selectedLbl.Text = #settings.CurrentOption .. " selected"
                end
            end

            local optFrames = {}
            for _, option in ipairs(settings.Options or {}) do
                local optBtn = Instance.new("TextButton")
                optBtn.Size = UDim2.new(1, 0, 0, ITEM_H - 4)
                optBtn.BackgroundColor3 = table.find(settings.CurrentOption, option) 
                    and SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.7)
                    or SelectedTheme.Surface
                optBtn.Text = ""
                optBtn.BorderSizePixel = 0
                optBtn.ZIndex = 12
                optBtn.AutoButtonColor = false
                optBtn.Parent = optList
                makeRound(optBtn, 6)
                optFrames[option] = optBtn

                local optLbl = Instance.new("TextLabel")
                optLbl.Size = UDim2.new(1, -16, 1, 0)
                optLbl.Position = UDim2.new(0, 10, 0, 0)
                optLbl.BackgroundTransparency = 1
                optLbl.Text = option
                optLbl.TextColor3 = table.find(settings.CurrentOption, option) 
                    and SelectedTheme.Accent 
                    or SelectedTheme.TextSecondary
                optLbl.Font = Enum.Font.Gotham
                optLbl.TextSize = 12
                optLbl.TextXAlignment = Enum.TextXAlignment.Left
                optLbl.Parent = optBtn

                -- Check mark
                local check = Instance.new("TextLabel")
                check.Size = UDim2.new(0, 16, 1, 0)
                check.Position = UDim2.new(1, -20, 0, 0)
                check.BackgroundTransparency = 1
                check.Text = "✓"
                check.TextColor3 = SelectedTheme.Accent
                check.Font = Enum.Font.GothamBold
                check.TextSize = 12
                check.TextTransparency = table.find(settings.CurrentOption, option) and 0 or 1
                check.Parent = optBtn

                optBtn.MouseButton1Click:Connect(function()
                    if not settings.MultipleOptions then
                        for opt, frame in pairs(optFrames) do
                            local lbl = frame:FindFirstChildOfClass("TextLabel")
                            local chk = frame:FindFirstChild("TextLabel", true)
                            tween(frame, ease(0.2), {BackgroundColor3 = SelectedTheme.Surface})
                            for _, c in ipairs(frame:GetChildren()) do
                                if c:IsA("TextLabel") and c.Text == "✓" then
                                    tween(c, ease(0.2), {TextTransparency = 1})
                                elseif c:IsA("TextLabel") then
                                    tween(c, ease(0.2), {TextColor3 = SelectedTheme.TextSecondary})
                                end
                            end
                        end
                        settings.CurrentOption = {option}
                        tween(optBtn, ease(0.2), {BackgroundColor3 = SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.7)})
                        tween(optLbl, ease(0.2), {TextColor3 = SelectedTheme.Accent})
                        tween(check, ease(0.2), {TextTransparency = 0})
                    else
                        local idx = table.find(settings.CurrentOption, option)
                        if idx then
                            table.remove(settings.CurrentOption, idx)
                            tween(optBtn, ease(0.2), {BackgroundColor3 = SelectedTheme.Surface})
                            tween(optLbl, ease(0.2), {TextColor3 = SelectedTheme.TextSecondary})
                            tween(check, ease(0.2), {TextTransparency = 1})
                        else
                            table.insert(settings.CurrentOption, option)
                            tween(optBtn, ease(0.2), {BackgroundColor3 = SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.7)})
                            tween(optLbl, ease(0.2), {TextColor3 = SelectedTheme.Accent})
                            tween(check, ease(0.2), {TextTransparency = 0})
                        end
                    end
                    refreshSelected()
                    pcall(settings.Callback, settings.CurrentOption)
                    saveConfig()
                    if not settings.MultipleOptions then
                        -- Close after select
                        task.wait(0.1)
                        isOpen = false
                        tween(arrow, ease(0.3), {Rotation = 0})
                        tween(card, spring(0.4), {Size = UDim2.new(1, 0, 0, 50)})
                    end
                end)
            end

            local totalOptHeight = #settings.Options * ITEM_H + 10
            local interact = Instance.new("TextButton")
            interact.Size = UDim2.new(1, 0, 0, 50)
            interact.BackgroundTransparency = 1
            interact.Text = ""
            interact.ZIndex = 13
            interact.Parent = card

            interact.MouseButton1Click:Connect(function()
                if Debounce then return end
                isOpen = not isOpen
                if isOpen then
                    tween(arrow, ease(0.3), {Rotation = 180})
                    tween(card, spring(0.5), {Size = UDim2.new(1, 0, 0, 50 + totalOptHeight)})
                else
                    tween(arrow, ease(0.3), {Rotation = 0})
                    tween(card, spring(0.4), {Size = UDim2.new(1, 0, 0, 50)})
                end
            end)

            function settings:Set(option)
                if type(option) == "string" then option = {option} end
                settings.CurrentOption = option
                refreshSelected()
                for opt, frame in pairs(optFrames) do
                    local isSelected = table.find(settings.CurrentOption, opt)
                    tween(frame, ease(0.2), {BackgroundColor3 = isSelected and SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.7) or SelectedTheme.Surface})
                    for _, c in ipairs(frame:GetChildren()) do
                        if c:IsA("TextLabel") and c.Text == "✓" then
                            tween(c, ease(0.2), {TextTransparency = isSelected and 0 or 1})
                        elseif c:IsA("TextLabel") then
                            tween(c, ease(0.2), {TextColor3 = isSelected and SelectedTheme.Accent or SelectedTheme.TextSecondary})
                        end
                    end
                end
                pcall(settings.Callback, settings.CurrentOption)
                saveConfig()
            end

            if settings.Flag and config.ConfigurationSaving and config.ConfigurationSaving.Enabled then
                ModernUI.Flags[settings.Flag] = settings
            end

            return settings
        end

        -- Keybind
        function Tab:CreateKeybind(settings)
            settings.Type = "Keybind"
            local listening = false
            local card = makeCard(50)

            local titleLbl = Instance.new("TextLabel")
            titleLbl.Size = UDim2.new(0.6, 0, 1, 0)
            titleLbl.Position = UDim2.new(0, 14, 0, 0)
            titleLbl.BackgroundTransparency = 1
            titleLbl.Text = settings.Name or "Keybind"
            titleLbl.TextColor3 = SelectedTheme.TextPrimary
            titleLbl.Font = Enum.Font.GothamSemibold
            titleLbl.TextSize = 13
            titleLbl.TextXAlignment = Enum.TextXAlignment.Left
            titleLbl.Parent = card

            -- Key badge
            local badge = Instance.new("Frame")
            badge.Size = UDim2.new(0, 60, 0, 28)
            badge.Position = UDim2.new(1, -72, 0.5, -14)
            badge.BackgroundColor3 = SelectedTheme.Background
            badge.BorderSizePixel = 0
            badge.ZIndex = 4
            badge.Parent = card
            makeRound(badge, 6)
            makeStroke(badge, SelectedTheme.Border, 1, 0)

            local keyLbl = Instance.new("TextLabel")
            keyLbl.Size = UDim2.new(1, 0, 1, 0)
            keyLbl.BackgroundTransparency = 1
            keyLbl.Text = settings.CurrentKeybind or "None"
            keyLbl.TextColor3 = SelectedTheme.Accent
            keyLbl.Font = Enum.Font.GothamBold
            keyLbl.TextSize = 12
            keyLbl.ZIndex = 5
            keyLbl.Parent = badge

            local interact = Instance.new("TextButton")
            interact.Size = UDim2.new(1, 0, 1, 0)
            interact.BackgroundTransparency = 1
            interact.Text = ""
            interact.ZIndex = 6
            interact.Parent = card

            interact.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                keyLbl.Text = "..."
                tween(badge, ease(0.2), {BackgroundColor3 = SelectedTheme.Accent:Lerp(SelectedTheme.Background, 0.8)})

                local conn; conn = UserInputService.InputBegan:Connect(function(inp, proc)
                    if proc then return end
                    if inp.KeyCode ~= Enum.KeyCode.Unknown then
                        local keyName = inp.KeyCode.Name
                        settings.CurrentKeybind = keyName
                        keyLbl.Text = keyName
                        tween(badge, ease(0.2), {BackgroundColor3 = SelectedTheme.Background})
                        listening = false
                        conn:Disconnect()
                        if settings.CallOnChange then
                            pcall(settings.Callback, keyName)
                        end
                        saveConfig()
                    end
                end)
            end)

            -- Key trigger
            local keybindConn = UserInputService.InputBegan:Connect(function(inp, proc)
                if proc or listening then return end
                if settings.CurrentKeybind and inp.KeyCode == Enum.KeyCode[settings.CurrentKeybind] then
                    if not settings.CallOnChange then
                        pcall(settings.Callback, settings.CurrentKeybind)
                    end
                end
            end)
            table.insert(keybindConns, keybindConn)

            function settings:Set(keybind)
                settings.CurrentKeybind = keybind
                keyLbl.Text = keybind
                if settings.CallOnChange then
                    pcall(settings.Callback, keybind)
                end
                saveConfig()
            end

            if settings.Flag and config.ConfigurationSaving and config.ConfigurationSaving.Enabled then
                ModernUI.Flags[settings.Flag] = settings
            end

            return settings
        end

        return Tab
    end

    -- Window-level API
    function WindowObj:ModifyTheme(newTheme)
        if type(newTheme) == "string" then
            SelectedTheme = ModernUI.Theme[newTheme] or ModernUI.Theme.Default
        elseif type(newTheme) == "table" then
            SelectedTheme = newTheme
        end
    end

    function WindowObj:SetVisibility(visible)
        Hidden = not visible
        if visible then
            Window.Visible = true
            tween(Window, spring(0.5), {BackgroundTransparency = 0})
        else
            tween(Window, ease(0.4), {BackgroundTransparency = 1})
            task.delay(0.4, function() Window.Visible = false end)
        end
    end

    function WindowObj:LoadConfiguration()
        loadConfig()
        globalLoaded = true
    end

    -- Fade in
    Window.BackgroundTransparency = 1
    tween(Window, spring(0.7), {BackgroundTransparency = 0})

    return WindowObj
end

function ModernUI:Destroy()
    destroyed = true
    for _, c in keybindConns do c:Disconnect() end
    ScreenGui:Destroy()
end

function ModernUI:SetVisibility(v)
    if ActiveWindow then ActiveWindow:SetVisibility(v) end
end

return ModernUI
