            icon.TextColor3        = SelectedTheme.TextMuted
            icon.Parent            = searchFrame

            local box = Instance.new("TextBox")
            box.Size               = UDim2.new(1, -40, 1, 0)
            box.Position           = UDim2.new(0, 30, 0, 0)
            box.BackgroundTransparency = 1
            box.PlaceholderText    = "Search elements..."
            box.PlaceholderColor3  = SelectedTheme.TextMuted
            box.TextColor3         = SelectedTheme.TextPrimary
            box.Font               = Enum.Font.Gotham
            box.TextSize           = 13
            box.TextXAlignment     = Enum.TextXAlignment.Left
            box.ClearTextOnFocus   = false
            box.Parent             = searchFrame

            box.Focused:Connect(function()
                tween(sStroke, ease(0.2), {Color = SelectedTheme.BorderAccent})
            end)
            box.FocusLost:Connect(function()
                tween(sStroke, ease(0.2), {Color = SelectedTheme.Border})
            end)

            box:GetPropertyChangedSignal("Text"):Connect(function()
                local query = box.Text:lower()
                for _, child in ipairs(Page:GetChildren()) do
                    if child:IsA("Frame") or child:IsA("ScrollingFrame") then
                        local lbl = child:FindFirstChildOfClass("TextLabel")
                        if lbl and child ~= searchFrame then
                            local match = query == ""
                                or lbl.Text:lower():find(query, 1, true)
                            child.Visible = match ~= nil
                        end
                    end
                end
            end)

            return box
        end

        return Tab
    end

    -- ── Window Utilities ──────────────────────────────────────

    function WindowObj:Notify(data)
        ModernUI:Notify(data)
    end

    function WindowObj:ModifyTheme(newTheme)
        if type(newTheme) == "string" then
            SelectedTheme = ModernUI.Theme[newTheme] or ModernUI.Theme.Default
        elseif type(newTheme) == "table" then
            SelectedTheme = setmetatable(newTheme, {__index = ModernUI.Theme.Default})
        end
        -- Note: live theme update would require re-theming all elements
    end

    function WindowObj:SetVisibility(visible)
        Hidden = not visible
        if visible then
            Window.Visible = true
            tween(Window, spring(0.5), {BackgroundTransparency = 0})
        else
            tween(Window, ease(0.35), {BackgroundTransparency = 1})
            task.delay(0.4, function()
                if Hidden then Window.Visible = false end
            end)
        end
    end

    function WindowObj:SetTitle(title)
        TitleLabel.Text = title
    end

    function WindowObj:LoadConfiguration()
        loadConfig()
        globalLoaded = true
    end

    -- Fade in
    tween(Window, spring(0.7), {BackgroundTransparency = 0})

    table.insert(ModernUI.Windows, WindowObj)
    return WindowObj
end

-- ═══════════════════════════════════════════════════════════════
-- GLOBAL METHODS
-- ═══════════════════════════════════════════════════════════════

function ModernUI:Destroy()
    if destroyed then return end
    destroyed = true
    for _, c in ipairs(keybindConns) do
        pcall(function() c:Disconnect() end)
    end
    pcall(function() ScreenGui:Destroy() end)
end

function ModernUI:SetTheme(name)
    SelectedTheme = ModernUI.Theme[name] or ModernUI.Theme.Default
end

function ModernUI:GetTheme()
    return SelectedTheme
end

function ModernUI:RegisterTheme(name, themeData)
    assert(type(name) == "string", "Theme name must be string")
    assert(type(themeData) == "table", "Theme data must be table")
    ModernUI.Theme[name] = setmetatable(themeData, {__index = ModernUI.Theme.Default})
end

return ModernUI
