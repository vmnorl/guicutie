            arrow.Size             = UDim2.new(0,22,0,22)
            arrow.Position         = UDim2.new(1,-30,0,15)
            arrow.BackgroundTransparency = 1
            arrow.Text             = "▾"
            arrow.TextColor3       = SelectedTheme.TextMuted
            arrow.Font             = Enum.Font.GothamBold
            arrow.TextSize         = 14
            arrow.Parent           = card

            local optFrame = Instance.new("Frame")
            optFrame.Size             = UDim2.new(1,-28,0,0)
            optFrame.Position         = UDim2.new(0,14,0,52)
            optFrame.BackgroundTransparency = 1
            optFrame.ZIndex           = 11
            optFrame.Parent           = card

            local optLayout = Instance.new("UIListLayout")
            optLayout.Parent    = optFrame
            optLayout.SortOrder = Enum.SortOrder.LayoutOrder
            optLayout.Padding   = UDim.new(0,3)

            local div = Instance.new("Frame")
            div.Size            = UDim2.new(1,0,0,1)
            div.BackgroundColor3 = SelectedTheme.Border
            div.BorderSizePixel = 0
            div.LayoutOrder     = 0
            div.Parent          = optFrame

            local optBtns    = {}
            local totalOptH  = 2

            local function refreshLabel()
                if #settings.CurrentOption == 0 then
                    selLbl.Text = "None"
                elseif #settings.CurrentOption == 1 then
                    selLbl.Text = settings.CurrentOption[1]
                else
                    selLbl.Text = #settings.CurrentOption .. " selected"
                end
            end
            refreshLabel()

            for _, opt in ipairs(settings.Options) do
                local isSel = table.find(settings.CurrentOption, opt) ~= nil
                local btn   = Instance.new("TextButton")
                btn.Size            = UDim2.new(1,0,0,ITEM_H-4)
                btn.BackgroundColor3 = isSel
                    and SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.72)
                    or  SelectedTheme.Surface
                btn.Text            = ""
                btn.BorderSizePixel = 0
                btn.ZIndex          = 12
                btn.AutoButtonColor = false
                btn.LayoutOrder     = 1
                btn.Parent          = optFrame
                makeRound(btn, 6)
                optBtns[opt] = btn
                totalOptH   += ITEM_H - 1

                local oLbl = Instance.new("TextLabel")
                oLbl.Size            = UDim2.new(1,-28,1,0)
                oLbl.Position        = UDim2.new(0,10,0,0)
                oLbl.BackgroundTransparency = 1
                oLbl.Text            = opt
                oLbl.TextColor3      = isSel and SelectedTheme.Accent or SelectedTheme.TextSecondary
                oLbl.Font            = Enum.Font.Gotham
                oLbl.TextSize        = 12
                oLbl.TextXAlignment  = Enum.TextXAlignment.Left
                oLbl.ZIndex          = 13
                oLbl.Parent          = btn

                local chk = Instance.new("TextLabel")
                chk.Size             = UDim2.new(0,18,1,0)
                chk.Position         = UDim2.new(1,-22,0,0)
                chk.BackgroundTransparency = 1
                chk.Text             = "✓"
                chk.TextColor3       = SelectedTheme.Accent
                chk.Font             = Enum.Font.GothamBold
                chk.TextSize         = 12
                chk.TextTransparency = isSel and 0 or 1
                chk.ZIndex           = 13
                chk.Parent           = btn

                btn.MouseEnter:Connect(function()
                    tween(btn, ease(0.15), {BackgroundColor3 = SelectedTheme.SurfaceHover})
                end)
                btn.MouseLeave:Connect(function()
                    local s = table.find(settings.CurrentOption, opt) ~= nil
                    tween(btn, ease(0.15), {
                        BackgroundColor3 = s
                            and SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.72)
                            or  SelectedTheme.Surface
                    })
                end)

                btn.MouseButton1Click:Connect(function()
                    if settings.MultipleOptions then
                        local idx = table.find(settings.CurrentOption, opt)
                        if idx then
                            table.remove(settings.CurrentOption, idx)
                            tween(btn,  ease(0.2), {BackgroundColor3 = SelectedTheme.Surface})
                            tween(oLbl, ease(0.2), {TextColor3 = SelectedTheme.TextSecondary})
                            tween(chk,  ease(0.2), {TextTransparency = 1})
                        else
                            table.insert(settings.CurrentOption, opt)
                            tween(btn,  ease(0.2), {BackgroundColor3 = SelectedTheme.Accent:Lerp(SelectedTheme.Surface,0.72)})
                            tween(oLbl, ease(0.2), {TextColor3 = SelectedTheme.Accent})
                            tween(chk,  ease(0.2), {TextTransparency = 0})
                        end
                    else
                        for o, b in pairs(optBtns) do
                            tween(b, ease(0.2), {BackgroundColor3 = SelectedTheme.Surface})
                            for _, c in ipairs(b:GetChildren()) do
                                if c:IsA("TextLabel") then
                                    if c.Text == "✓" then
                                        tween(c, ease(0.2), {TextTransparency = 1})
                                    else
                                        tween(c, ease(0.2), {TextColor3 = SelectedTheme.TextSecondary})
                                    end
                                end
                            end
                        end
                        settings.CurrentOption = {opt}
                        tween(btn,  ease(0.2), {BackgroundColor3 = SelectedTheme.Accent:Lerp(SelectedTheme.Surface,0.72)})
                        tween(oLbl, ease(0.2), {TextColor3 = SelectedTheme.Accent})
                        tween(chk,  ease(0.2), {TextTransparency = 0})
                    end
                    refreshLabel()
                    safecall(settings.Callback, settings.CurrentOption)
                    saveConfig()
                    if not settings.MultipleOptions then
                        task.wait(0.08)
                        isOpen = false
                        tween(arrow, ease(0.3), {Rotation = 0})
                        tween(card,  spring(0.4), {Size = UDim2.new(1,0,0,52)})
                    end
                end)
            end

            local ghost = Instance.new("TextButton")
            ghost.Size               = UDim2.new(1,0,0,52)
            ghost.BackgroundTransparency = 1
            ghost.Text               = ""
            ghost.ZIndex             = 14
            ghost.Parent             = card

            ghost.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    tween(arrow, ease(0.3),  {Rotation = 180})
                    tween(card,  spring(0.5),{Size = UDim2.new(1,0,0,52+totalOptH+6)})
                else
                    tween(arrow, ease(0.3),  {Rotation = 0})
                    tween(card,  spring(0.4),{Size = UDim2.new(1,0,0,52)})
                end
            end)

            function settings:Set(opt)
                if type(opt) == "string" then opt = {opt} end
                settings.CurrentOption = opt
                refreshLabel()
                for o, b in pairs(optBtns) do
                    local s = table.find(settings.CurrentOption, o) ~= nil
                    tween(b, ease(0.2), {
                        BackgroundColor3 = s
                            and SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.72)
                            or  SelectedTheme.Surface
                    })
                    for _, c in ipairs(b:GetChildren()) do
                        if c:IsA("TextLabel") then
                            if c.Text == "✓" then
                                tween(c, ease(0.2), {TextTransparency = s and 0 or 1})
                            else
                                tween(c, ease(0.2), {TextColor3 = s and SelectedTheme.Accent or SelectedTheme.TextSecondary})
                            end
                        end
                    end
                end
                safecall(settings.Callback, settings.CurrentOption)
                saveConfig()
            end

            if settings.Flag and CEnabled then
                ModernUI.Flags[settings.Flag] = settings
            end
            return settings
        end

