        titleLbl.Parent            = notif

        -- Content
        local contentLbl = Instance.new("TextLabel")
        contentLbl.Size              = UDim2.new(1, -68, 0, 0)
        contentLbl.Position          = UDim2.new(0, 54, 0, 31)
        contentLbl.BackgroundTransparency = 1
        contentLbl.Text              = data.Content or ""
        contentLbl.TextColor3        = SelectedTheme.TextSecondary
        contentLbl.TextTransparency  = 1
        contentLbl.Font              = Enum.Font.Gotham
        contentLbl.TextSize          = 11
        contentLbl.TextXAlignment    = Enum.TextXAlignment.Left
        contentLbl.TextWrapped       = true
        contentLbl.AutomaticSize     = Enum.AutomaticSize.Y
        contentLbl.Parent            = notif

        -- Close btn
        local closeBtn = Instance.new("TextButton")
        closeBtn.Size              = UDim2.new(0, 18, 0, 18)
        closeBtn.Position          = UDim2.new(1,-24,0,6)
        closeBtn.BackgroundTransparency = 1
        closeBtn.Text              = "×"
        closeBtn.TextColor3        = SelectedTheme.TextMuted
        closeBtn.Font              = Enum.Font.GothamBold
        closeBtn.TextSize          = 16
        closeBtn.ZIndex            = 5
        closeBtn.Parent            = notif

        -- Progress bar
        local progBg = Instance.new("Frame")
        progBg.Size            = UDim2.new(1,-16,0,2)
        progBg.Position        = UDim2.new(0,8,1,-5)
        progBg.BackgroundColor3 = SelectedTheme.Border
        progBg.BorderSizePixel = 0
        progBg.Parent          = notif
        makeRound(progBg, 1)

        local progFill = Instance.new("Frame")
        progFill.Size            = UDim2.new(1,0,1,0)
        progFill.BackgroundColor3 = accent
        progFill.BorderSizePixel = 0
        progFill.Parent          = progBg
        makeRound(progFill, 1)

        task.wait(0.05)
        local textH  = contentLbl.TextBounds.Y
        local totalH = math.max(textH + 58, 74)

        tween(wrapper, spring(0.5), {Size = UDim2.new(1,0,0,totalH+6)})
        tween(notif, spring(0.5), {BackgroundTransparency = 0.06})
        task.wait(0.12)
        tween(titleLbl,   ease(0.35), {TextTransparency = 0})
        tween(contentLbl, ease(0.35), {TextTransparency = 0.08})

        local duration = data.Duration
            or math.clamp(#(data.Content or "") * 0.055 + 3.5, 3.5, 12)

        tween(progFill, TweenInfo.new(duration, Enum.EasingStyle.Linear),
            {Size = UDim2.new(0,0,1,0)})

        local dismissed = false
        local function dismiss()
            if dismissed then return end
            dismissed = true
            tween(notif,    ease(0.3), {BackgroundTransparency = 1})
            tween(titleLbl, ease(0.2), {TextTransparency = 1})
            tween(contentLbl, ease(0.2), {TextTransparency = 1})
            tween(wrapper,  spring(0.4), {Size = UDim2.new(1,0,0,0)})
            task.wait(0.45)
            pcall(function() wrapper:Destroy() end)
        end

        closeBtn.MouseButton1Click:Connect(dismiss)
        task.wait(duration)
        dismiss()
    end)
end

