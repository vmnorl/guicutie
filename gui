-- ═══════════════════════════════════════════════════════════════
-- DRAGGING SYSTEM (FIXED - stays within screen bounds)
-- ═══════════════════════════════════════════════════════════════

local function makeDraggable(frame, handle)
    local dragging   = false
    local dragStart  = nil
    local startPos   = nil

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging   = true
            dragStart  = input.Position
            startPos   = frame.Position
        end
    end)

    local c1 = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    local c2 = RunService.Heartbeat:Connect(function()
        if not dragging or Hidden then return end
        
        local mouse = UserInputService:GetMouseLocation()
        local delta = mouse - dragStart
        
        -- Calculate new position
        local newX = startPos.X.Offset + delta.X
        local newY = startPos.Y.Offset + delta.Y
        
        -- Get viewport size
        local vpSize = workspace.CurrentCamera.ViewportSize
        
        -- Clamp position to keep window on screen
        newX = math.clamp(newX, 0, vpSize.X - frame.AbsoluteSize.X)
        newY = math.clamp(newY, 0, vpSize.Y - frame.AbsoluteSize.Y)
        
        -- Apply position (using offset only, no scale)
        frame.Position = UDim2.new(0, newX, 0, newY)
    end)

    frame.Destroying:Connect(function()
        pcall(function() c1:Disconnect() end)
        pcall(function() c2:Disconnect() end)
    end)
end

