        -- Slider
        function Tab:CreateSlider(settings)
            settings.Type = "Slider"
            local card = makeCard(64)

            local titleLbl = Instance.new("TextLabel")
            titleLbl.Size = UDim2.new(1, -80, 0, 20)
            titleLbl.Position = UDim2.new(0, 14, 0, 8)
            titleLbl.BackgroundTransparency = 1
            titleLbl.Text = settings.Name or "Slider"
            titleLbl.TextColor3 = SelectedTheme.TextPrimary
            titleLbl.Font = Enum.Font.GothamSemibold
            titleLbl.TextSize = 13
            titleLbl.TextXAlignment = Enum.TextXAlignment.Left
            titleLbl.Parent = card

            local valueLbl = Instance.new("TextLabel")
            valueLbl.Size = UDim2.new(0, 70, 0, 20)
            valueLbl.Position = UDim2.new(1, -84, 0, 8)
            valueLbl.BackgroundTransparency = 1
            valueLbl.Text = tostring(settings.CurrentValue) .. (settings.Suffix and " " .. settings.Suffix or "")
            valueLbl.TextColor3 = SelectedTheme.Accent
            valueLbl.Font = Enum.Font.GothamBold
            valueLbl.TextSize = 13
            valueLbl.TextXAlignment = Enum.TextXAlignment.Right
            valueLbl.Parent = card

            -- Track
            local trackBg = Instance.new("Frame")
            trackBg.Size = UDim2.new(1, -28, 0, 6)
            trackBg.Position = UDim2.new(0, 14, 0, 40)
            trackBg.BackgroundColor3 = SelectedTheme.SliderTrack
            trackBg.BorderSizePixel = 0
            trackBg.ZIndex = 4
            trackBg.Parent = card
            makeRound(trackBg, 3)

            local trackFill = Instance.new("Frame")
            trackFill.Size = UDim2.new(
                (settings.CurrentValue - settings.Range[1]) / (settings.Range[2] - settings.Range[1]),
                0, 1, 0
            )
            trackFill.BackgroundColor3 = SelectedTheme.SliderFill
            trackFill.BorderSizePixel = 0
            trackFill.ZIndex = 5
            trackFill.Parent = trackBg
            makeRound(trackFill, 3)

            -- Thumb
            local thumb = Instance.new("Frame")
            thumb.Size = UDim2.new(0, 14, 0, 14)
            thumb.AnchorPoint = Vector2.new(0.5, 0.5)
            local pct = (settings.CurrentValue - settings.Range[1]) / (settings.Range[2] - settings.Range[1])
            thumb.Position = UDim2.new(pct, 0, 0.5, 0)
            thumb.BackgroundColor3 = SelectedTheme.ToggleKnob
            thumb.BorderSizePixel = 0
            thumb.ZIndex = 6
            thumb.Parent = trackBg
            makeRound(thumb, 7)
            makeStroke(thumb, SelectedTheme.Accent, 2, 0)

            local dragging = false
            local interactBtn = Instance.new("TextButton")
            interactBtn.Size = UDim2.new(1, 0, 0, 30)
            interactBtn.Position = UDim2.new(0, 0, 0, -12)
            interactBtn.BackgroundTransparency = 1
            interactBtn.Text = ""
            interactBtn.ZIndex = 7
            interactBtn.Parent = trackBg

            local function updateSlider(mouseX)
                local rel = math.clamp((mouseX - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
                local raw = settings.Range[1] + rel * (settings.Range[2] - settings.Range[1])
                local snapped = math.floor(raw / settings.Increment + 0.5) * settings.Increment
                snapped = math.clamp(snapped, settings.Range[1], settings.Range[2])
                local newPct = (snapped - settings.Range[1]) / (settings.Range[2] - settings.Range[1])
                tween(trackFill, ease(0.1), {Size = UDim2.new(newPct, 0, 1, 0)})
                tween(thumb, ease(0.1), {Position = UDim2.new(newPct, 0, 0.5, 0)})
                valueLbl.Text = tostring(snapped) .. (settings.Suffix and " " .. settings.Suffix or "")
                if settings.CurrentValue ~= snapped then
                    settings.CurrentValue = snapped
                    pcall(settings.Callback, snapped)
                    saveConfig()
                end
            end

            interactBtn.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    updateSlider(inp.Position.X)
                end
            end)

            local sliderConn = UserInputService.InputChanged:Connect(function(inp)
                if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
                    updateSlider(inp.Position.X)
                end
            end)
            local sliderEndConn = UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            card.Destroying:Connect(function()
                sliderConn:Disconnect()
                sliderEndConn:Disconnect()
            end)

            function settings:Set(value)
                value = math.clamp(value, settings.Range[1], settings.Range[2])
                settings.CurrentValue = value
                local newPct = (value - settings.Range[1]) / (settings.Range[2] - settings.Range[1])
                tween(trackFill, spring(0.4), {Size = UDim2.new(newPct, 0, 1, 0)})
                tween(thumb, spring(0.4), {Position = UDim2.new(newPct, 0, 0.5, 0)})
                valueLbl.Text = tostring(value) .. (settings.Suffix and " " .. settings.Suffix or "")
                pcall(settings.Callback, value)
                saveConfig()
            end

            if settings.Flag and config.ConfigurationSaving and config.ConfigurationSaving.Enabled then
                ModernUI.Flags[settings.Flag] = settings
            end

            return settings
        end

