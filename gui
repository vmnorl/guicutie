        -- ══════════════════════════════════════════════════════
        function Tab:CreateSlider(settings)
            assert(type(settings) == "table", "[ModernUI] CreateSlider expects a table")
            settings.Type         = "Slider"
            settings.CurrentValue = settings.CurrentValue or settings.Range[1]
            settings.Increment    = settings.Increment or 1

            local card = makeCard(68)

            local nameLbl = Instance.new("TextLabel")
            nameLbl.Size             = UDim2.new(1, -90, 0, 20)
            nameLbl.Position         = UDim2.new(0, 14, 0, 8)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text             = settings.Name or "Slider"
            nameLbl.TextColor3       = SelectedTheme.TextPrimary
            nameLbl.Font             = Enum.Font.GothamSemibold
            nameLbl.TextSize         = 13
            nameLbl.TextXAlignment   = Enum.TextXAlignment.Left
            nameLbl.Parent           = card

            local valueLbl = Instance.new("TextLabel")
            valueLbl.Size              = UDim2.new(0, 80, 0, 20)
            valueLbl.Position          = UDim2.new(1, -92, 0, 8)
            valueLbl.BackgroundTransparency = 1
            valueLbl.Font              = Enum.Font.GothamBold
            valueLbl.TextSize          = 13
            valueLbl.TextXAlignment    = Enum.TextXAlignment.Right
            valueLbl.TextColor3        = SelectedTheme.Accent
            valueLbl.Parent            = card

            -- Description
            if settings.Description then
                nameLbl.Size     = UDim2.new(1, -90, 0, 16)
                card.Size        = UDim2.new(1, 0, 0, 82)
                local dLbl = Instance.new("TextLabel")
                dLbl.Size              = UDim2.new(1, -90, 0, 12)
                dLbl.Position          = UDim2.new(0, 14, 0, 24)
                dLbl.BackgroundTransparency = 1
                dLbl.Text              = settings.Description
                dLbl.TextColor3        = SelectedTheme.TextMuted
                dLbl.Font              = Enum.Font.Gotham
                dLbl.TextSize          = 11
                dLbl.TextXAlignment    = Enum.TextXAlignment.Left
                dLbl.Parent            = card
            end

            local trackY = settings.Description and 50 or 42

            -- Track background
            local trackBg = Instance.new("Frame")
            trackBg.Size            = UDim2.new(1, -28, 0, 6)
            trackBg.Position        = UDim2.new(0, 14, 0, trackY)
            trackBg.BackgroundColor3 = SelectedTheme.SliderTrack
            trackBg.BorderSizePixel = 0
            trackBg.ZIndex          = 4
            trackBg.Parent          = card
            makeRound(trackBg, 3)

            local pctInit = (settings.CurrentValue - settings.Range[1])
                / (settings.Range[2] - settings.Range[1])

            -- Fill
            local trackFill = Instance.new("Frame")
            trackFill.Size            = UDim2.new(pctInit, 0, 1, 0)
            trackFill.BackgroundColor3 = SelectedTheme.SliderFill
            trackFill.BorderSizePixel = 0
            trackFill.ZIndex          = 5
            trackFill.Parent          = trackBg
            makeRound(trackFill, 3)

            -- Thumb
            local thumb = Instance.new("Frame")
            thumb.Size            = UDim2.new(0, 16, 0, 16)
            thumb.AnchorPoint     = Vector2.new(0.5, 0.5)
            thumb.Position        = UDim2.new(pctInit, 0, 0.5, 0)
            thumb.BackgroundColor3 = SelectedTheme.ToggleKnob
            thumb.BorderSizePixel = 0
            thumb.ZIndex          = 6
            thumb.Parent          = trackBg
            makeRound(thumb, 8)
            makeStroke(thumb, SelectedTheme.Accent, 2, 0)

            valueLbl.Text = tostring(settings.CurrentValue)
                .. (settings.Suffix and " " .. settings.Suffix or "")

            -- Hit area
            local hitArea = Instance.new("TextButton")
            hitArea.Size               = UDim2.new(1, 0, 0, 34)
            hitArea.Position           = UDim2.new(0, 0, 0, -14)
            hitArea.BackgroundTransparency = 1
            hitArea.Text               = ""
            hitArea.ZIndex             = 7
            hitArea.Parent             = trackBg

            local draggingSlider = false

            local function updateSlider(mouseX)
                local rel  = math.clamp(
                    (mouseX - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X,
                    0, 1
                )
                local raw  = settings.Range[1] + rel * (settings.Range[2] - settings.Range[1])
                local snapped = math.floor(raw / settings.Increment + 0.5) * settings.Increment
                snapped = math.clamp(snapped, settings.Range[1], settings.Range[2])
                local newPct = (snapped - settings.Range[1]) / (settings.Range[2] - settings.Range[1])

                tween(trackFill, ease(0.08), {Size = UDim2.new(newPct, 0, 1, 0)})
                tween(thumb, ease(0.08), {Position = UDim2.new(newPct, 0, 0.5, 0)})

                valueLbl.Text = tostring(snapped)
                    .. (settings.Suffix and " " .. settings.Suffix or "")

                if settings.CurrentValue ~= snapped then
                    settings.CurrentValue = snapped
                    safecall(settings.Callback, snapped)
                    saveConfig()
                end
            end

            hitArea.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    draggingSlider = true
                    updateSlider(inp.Position.X)
                end
            end)

            local sc1 = UserInputService.InputChanged:Connect(function(inp)
                if draggingSlider
                and (inp.UserInputType == Enum.UserInputType.MouseMovement
                  or inp.UserInputType == Enum.UserInputType.Touch) then
                    updateSlider(inp.Position.X)
                end
            end)
            local sc2 = UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    draggingSlider = false
                end
            end)
            card.Destroying:Connect(function()
                sc1:Disconnect()
                sc2:Disconnect()
            end)

            function settings:Set(v)
                v = math.clamp(v, settings.Range[1], settings.Range[2])
                settings.CurrentValue = v
                local p = (v - settings.Range[1]) / (settings.Range[2] - settings.Range[1])
                tween(trackFill, spring(0.4), {Size = UDim2.new(p, 0, 1, 0)})
                tween(thumb, spring(0.4), {Position = UDim2.new(p, 0, 0.5, 0)})
                valueLbl.Text = tostring(v) .. (settings.Suffix and " " .. settings.Suffix or "")
                safecall(settings.Callback, v)
                saveConfig()
            end

            if settings.Flag and CEnabled then
                ModernUI.Flags[settings.Flag] = settings
            end
            return settings
        end

