-- ═══════════════════════════════════════════════════════════════
-- UTILITIES
-- ═══════════════════════════════════════════════════════════════

local function tween(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function tweenAwait(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    t.Completed:Wait()
end

local function spring(t, style, dir)
    return TweenInfo.new(
        t or 0.5,
        style or Enum.EasingStyle.Exponential,
        dir or Enum.EasingDirection.Out
    )
end

local function ease(t, style, dir)
    return TweenInfo.new(
        t or 0.4,
        style or Enum.EasingStyle.Quint,
        dir or Enum.EasingDirection.Out
    )
end

local function bounce(t)
    return TweenInfo.new(t or 0.5, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out)
end

local function safecall(f, ...)
    if type(f) ~= "function" then return false, "not a function" end
    local args = {...}
    local ok, err = pcall(function() return f(table.unpack(args)) end)
    if not ok then
        warn("[ModernUI] Callback error: " .. tostring(err))
    end
    return ok, err
end

local function ensureFolder(path)
    if isfolder and not isfolder(path) then
        makefolder(path)
    end
end

local function round(n, dec)
    local mult = 10^(dec or 0)
    return math.floor(n * mult + 0.5) / mult
end

local function lerpColor(c1, c2, t)
    return c1:Lerp(c2, t)
end

local function hexToColor(hex)
    hex = hex:gsub("#", "")
    return Color3.fromRGB(
        tonumber(hex:sub(1,2), 16) or 0,
        tonumber(hex:sub(3,4), 16) or 0,
        tonumber(hex:sub(5,6), 16) or 0
    )
end

local function colorToHex(c)
    return string.format("#%02X%02X%02X",
        math.floor(c.R * 255),
        math.floor(c.G * 255),
        math.floor(c.B * 255)
    )
end

local function hsvToColor(h, s, v)
    return Color3.fromHSV(h, s, v)
end

