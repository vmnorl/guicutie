            local panel = Instance.new("Frame")
            panel.Size            = UDim2.new(1, -28, 0, PICKER_H)
            panel.Position        = UDim2.new(0, 14, 0, 56)
            panel.BackgroundTransparency = 1
            panel.ZIndex          = 11
            panel.Parent          = card

            -- SV picker (saturation/value square)
            local svPicker = Instance.new("ImageLabel")
            svPicker.Size            = UDim2.new(0, 140, 0, 120)
            svPicker.Position        = UDim2.new(0, 0, 0, 0)
            svPicker.Image           = "rbxassetid://4155801252"
            svPicker.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            svPicker.BorderSizePixel = 0
            svPicker.ZIndex          = 12
            svPicker.Parent          = panel
            makeRound(svPicker, 6)

            -- SV cursor
            local svCursor = Instance.new("Frame")
            svCursor.Size            = UDim2.new(0, 12, 0, 12)
            svCursor.AnchorPoint     = Vector2.new(0.5, 0.5)
            svCursor.Position        = UDim2.new(s, 0, 1 - v, 0)
            svCursor.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            svCursor.BorderSizePixel = 0
            svCursor.ZIndex          = 13
            svCursor.Parent          = svPicker
            makeRound(svCursor, 6)
            makeStroke(svCursor, Color3.fromRGB(0,0,0), 1.5, 0)

            -- Hue bar
            local hueBar = Instance.new("ImageLabel")
            hueBar.Size            = UDim2.new(0, 16, 0, 120)
            hueBar.Position        = UDim2.new(0, 148, 0, 0)
            hueBar.Image           = "rbxassetid://698052001"
            hueBar.BackgroundColor3 = Color3.fromRGB(255,255,255)
            hueBar.BorderSizePixel = 0
            hueBar.ZIndex          = 12
            hueBar.Parent          = panel
            makeRound(hueBar, 4)

            local hueCursor = Instance.new("Frame")
            hueCursor.Size            = UDim2.new(1, 4, 0, 4)
            hueCursor.Position        = UDim2.new(0, -2, h, -2)
            hueCursor.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            hueCursor.BorderSizePixel = 0
            hueCursor.ZIndex          = 13
            hueCursor.Parent          = hueBar
            makeRound(hueCursor, 2)
            makeStroke(hueCursor, Color3.fromRGB(0,0,0), 1, 0)

            -- Alpha bar
            local alphaVal = 1
            local alphaBar = Instance.new("Frame")
            alphaBar.Size            = UDim2.new(0, 16, 0, 120)
            alphaBar.Position        = UDim2.new(0, 172, 0, 0)
            alphaBar.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
            alphaBar.BorderSizePixel = 0
            alphaBar.ZIndex          = 12
            alphaBar.Parent          = panel
            makeRound(alphaBar, 4)

            local alphaGrad = Instance.new("UIGradient")
            alphaGrad.Rotation = 90
            alphaGrad.Color    = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0)),
            })
            alphaGrad.Parent = alphaBar

            local alphaCursor = Instance.new("Frame")
            alphaCursor.Size            = UDim2.new(1, 4, 0, 4)
            alphaCursor.Position        = UDim2.new(0, -2, 1 - alphaVal, -2)
            alphaCursor.BackgroundColor3 = Color3.fromRGB(255,255,255)
            alphaCursor.BorderSizePixel = 0
            alphaCursor.ZIndex          = 13
            alphaCursor.Parent          = alphaBar
            makeRound(alphaCursor, 2)
            makeStroke(alphaCursor, Color3.fromRGB(0,0,0), 1, 0)

            -- Hex input
            local hexBox = Instance.new("TextBox")
            hexBox.Size              = UDim2.new(0, 100, 0, 28)
            hexBox.Position          = UDim2.new(0, 0, 0, 132)
            hexBox.BackgroundColor3  = SelectedTheme.Background
            hexBox.Text              = colorToHex(settings.CurrentColor)
            hexBox.PlaceholderText   = "#FFFFFF"
            hexBox.PlaceholderColor3 = SelectedTheme.TextMuted
            hexBox.TextColor3        = SelectedTheme.TextPrimary
            hexBox.Font              = Enum.Font.GothamBold
            hexBox.TextSize          = 12
            hexBox.BorderSizePixel   = 0
            hexBox.ClearTextOnFocus  = false
            hexBox.ZIndex            = 12
            hexBox.Parent            = panel
            makeRound(hexBox, 6)
            makeStroke(hexBox, SelectedTheme.Border, 1, 0)

            -- Rgb readout
            local rgbLbl = Instance.new("TextLabel")
            rgbLbl.Size              = UDim2.new(0, 100, 0, 28)
            rgbLbl.Position          = UDim2.new(0, 108, 0, 132)
            rgbLbl.BackgroundTransparency = 1
            rgbLbl.TextColor3        = SelectedTheme.TextMuted
            rgbLbl.Font              = Enum.Font.Gotham
            rgbLbl.TextSize          = 10
            rgbLbl.Parent            = panel

            local function applyColor(newH, newS, newV, silent)
                h, s, v = newH, newS, newV
                local col = Color3.fromHSV(h, s, v)
                settings.CurrentColor = col
                preview.BackgroundColor3 = col
                svPicker.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                hueCursor.Position = UDim2.new(0, -2, h, -2)
                hexLbl.Text = colorToHex(col)
                hexBox.Text = colorToHex(col)
                rgbLbl.Text = string.format("R:%d G:%d B:%d",
                    math.floor(col.R * 255),
                    math.floor(col.G * 255),
                    math.floor(col.B * 255)
                )
                if not silent then
                    safecall(settings.Callback, col)
                    saveConfig()
                end
            end

            -- Drag SV picker
            local draggingSV  = false
            local draggingH   = false
            local draggingA   = false

            local svBtn = Instance.new("TextButton")
            svBtn.Size               = UDim2.new(1, 0, 1, 0)
            svBtn.BackgroundTransparency = 1
            svBtn.Text               = ""
            svBtn.ZIndex             = 14
            svBtn.Parent             = svPicker

            svBtn.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    draggingSV = true
                end
            end)

            local hBtn = Instance.new("TextButton")
            hBtn.Size               = UDim2.new(1, 0, 1, 0)
            hBtn.BackgroundTransparency = 1
            hBtn.Text               = ""
            hBtn.ZIndex             = 14
            hBtn.Parent             = hueBar

            hBtn.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    draggingH = true
                end
            end)

            local aBtn = Instance.new("TextButton")
            aBtn.Size               = UDim2.new(1, 0, 1, 0)
            aBtn.BackgroundTransparency = 1
            aBtn.Text               = ""
            aBtn.ZIndex             = 14
            aBtn.Parent             = alphaBar

            aBtn.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    draggingA = true
                end
            end)

            local cpConns = {}
            table.insert(cpConns, UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    draggingSV = false
                    draggingH  = false
                    draggingA  = false
                end
            end))
            table.insert(cpConns, UserInputService.InputChanged:Connect(function(inp)
                if not (inp.UserInputType == Enum.UserInputType.MouseMovement
                    or inp.UserInputType == Enum.UserInputType.Touch) then return end
                local mx, my = inp.Position.X, inp.Position.Y
                if draggingSV then
                    local ns = math.clamp((mx - svPicker.AbsolutePosition.X) / svPicker.AbsoluteSize.X, 0, 1)
                    local nv = 1 - math.clamp((my - svPicker.AbsolutePosition.Y) / svPicker.AbsoluteSize.Y, 0, 1)
                    applyColor(h, ns, nv)
                elseif draggingH then
                    local nh = math.clamp((my - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                    applyColor(nh, s, v)
                elseif draggingA then
                    alphaVal = 1 - math.clamp((my - alphaBar.AbsolutePosition.Y) / alphaBar.AbsoluteSize.Y, 0, 1)
                    alphaCursor.Position = UDim2.new(0, -2, 1 - alphaVal, -2)
                end
            end))

            card.Destroying:Connect(function()
                for _, c in ipairs(cpConns) do c:Disconnect() end
            end)

            hexBox.FocusLost:Connect(function()
                local txt = hexBox.Text
                pcall(function()
                    local col = hexToColor(txt)
                    local nh, ns, nv = Color3.toHSV(col)
                    applyColor(nh, ns, nv)
                end)
            end)

            -- Toggle open/close
            local ghost = Instance.new("TextButton")
            ghost.Size               = UDim2.new(1, 0, 0, 52)
            ghost.BackgroundTransparency = 1
            ghost.Text               = ""
            ghost.ZIndex             = 15
            ghost.Parent             = card

            ghost.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    tween(card, spring(0.5), {Size = UDim2.new(1, 0, 0, 52 + PICKER_H + 10)})
                else
                    tween(card, spring(0.4), {Size = UDim2.new(1, 0, 0, 52)})
                end
            end)

            -- Apply initial
            applyColor(h, s, v, true)

            function settings:Set(col)
                local nh, ns, nv = Color3.toHSV(col)
                applyColor(nh, ns, nv, false)
            end

            if settings.Flag and CEnabled then
                ModernUI.Flags[settings.Flag] = settings
            end
            return settings
        end

