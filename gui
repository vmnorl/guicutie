    local currentToggleConn = nil
    
    local function updateToggleKeybind(newKey)
        openKeybind = newKey
        
        -- Disconnect old connection
        if currentToggleConn then
            pcall(function() currentToggleConn:Disconnect() end)
        end
        
        -- Create new connection
        currentToggleConn = UserInputService.InputBegan:Connect(function(input, processed)
            if processed then return end
            local ok, kc = pcall(function() return Enum.KeyCode[openKeybind] end)
            if ok and input.KeyCode == kc then
                if Hidden then
                    Hidden         = false
                    Window.Visible = true
                    tween(Window, spring(0.5), {BackgroundTransparency = 0})
                else
                    Hidden = true
                    tween(Window, ease(0.35), {BackgroundTransparency = 1})
                    task.delay(0.38, function()
                        if Hidden then Window.Visible = false end
                    end)
                end
            end
        end)
        
        table.insert(keybindConns, currentToggleConn)
        saveConfig()
    end
    
