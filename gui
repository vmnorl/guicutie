            pill.MouseEnter:Connect(function()
                tween(pill, ease(0.2), {BackgroundColor3 = SelectedTheme.AccentHover})
            end)
            pill.MouseLeave:Connect(function()
                tween(pill, ease(0.2), {BackgroundColor3 = SelectedTheme.Accent})
            end)

            -- Ghost interact for full-card click
            local ghost = Instance.new("TextButton")
            ghost.Size               = UDim2.new(1, 0, 1, 0)
            ghost.BackgroundTransparency = 1
            ghost.Text               = ""
            ghost.ZIndex             = 3
            ghost.Parent             = card

            local busy = false
            local function doClick()
                if busy then return end
                busy = true
                tween(pill, ease(0.12), {BackgroundColor3 = SelectedTheme.AccentHover})
                local ok, err = safecall(settings.Callback)
                if not ok then
                    local orig = nameLbl.Text
                    nameLbl.TextColor3 = SelectedTheme.Error
                    nameLbl.Text = "⚠ Error occurred"
                    task.wait(2)
                    nameLbl.Text       = orig
                    nameLbl.TextColor3 = SelectedTheme.TextPrimary
                end
                task.wait(0.18)
                tween(pill, ease(0.25), {BackgroundColor3 = SelectedTheme.Accent})
                busy = false
            end

            ghost.MouseButton1Click:Connect(doClick)
            pill.MouseButton1Click:Connect(doClick)

            if settings.Tooltip then makeTooltip(card, settings.Tooltip) end

            local BtnObj = {}
            function BtnObj:Set(n) nameLbl.Text = n end
            function BtnObj:SetColor(c)
                tween(pill, ease(0.3), {BackgroundColor3 = c})
            end
            return BtnObj
        end

