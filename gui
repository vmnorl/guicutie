        -- KEYBIND
        -- ══════════════════════════════════════════════════════
        function Tab:CreateKeybind(settings)
            assert(type(settings) == "table", "[ModernUI] CreateKeybind expects a table")
            settings.Type           = "Keybind"
            settings.CurrentKeybind = settings.CurrentKeybind or "None"

            local listening = false
            local card      = makeCard(52)

            local nameLbl = Instance.new("TextLabel")
            nameLbl.Size             = UDim2.new(0.6, 0, 1, 0)
            nameLbl.Position         = UDim2.new(0, 14, 0, 0)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text             = settings.Name or "Keybind"
            nameLbl.TextColor3       = SelectedTheme.TextPrimary
            nameLbl.Font             = Enum.Font.GothamSemibold
            nameLbl.TextSize         = 13
            nameLbl.TextXAlignment   = Enum.TextXAlignment.Left
            nameLbl.Parent           = card

            local badge = Instance.new("Frame")
            badge.Size            = UDim2.new(0, 72, 0, 30)
            badge.Position        = UDim2.new(1, -84, 0.5, -15)
            badge.BackgroundColor3 = SelectedTheme.Background
            badge.BorderSizePixel = 0
            badge.ZIndex          = 4
            badge.Parent          = card
            makeRound(badge, 7)
            local badgeStroke = makeStroke(badge, SelectedTheme.Border, 1, 0)

            local keyLbl = Instance.new("TextLabel")
            keyLbl.Size              = UDim2.new(1, 0, 1, 0)
            keyLbl.BackgroundTransparency = 1
            keyLbl.Text              = settings.CurrentKeybind
            keyLbl.TextColor3        = SelectedTheme.Accent
            keyLbl.Font              = Enum.Font.GothamBold
            keyLbl.TextSize          = 11
            keyLbl.ZIndex            = 5
            keyLbl.Parent            = badge

            local ghost = Instance.new("TextButton")
            ghost.Size               = UDim2.new(1, 0, 1, 0)
            ghost.BackgroundTransparency = 1
            ghost.Text               = ""
            ghost.ZIndex             = 6
            ghost.Parent             = card

            ghost.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                keyLbl.Text = "..."
                tween(badgeStroke, ease(0.2), {Color = SelectedTheme.Accent})
                tween(badge, ease(0.2), {BackgroundColor3 = SelectedTheme.Accent:Lerp(SelectedTheme.Background, 0.85)})

                local conn; conn = UserInputService.InputBegan:Connect(function(inp, proc)
                    if proc then return end
                    if inp.KeyCode ~= Enum.KeyCode.Unknown then
                        local kn = inp.KeyCode.Name
                        settings.CurrentKeybind = kn
                        keyLbl.Text = kn
                        tween(badgeStroke, ease(0.2), {Color = SelectedTheme.Border})
                        tween(badge, ease(0.2), {BackgroundColor3 = SelectedTheme.Background})
                        listening = false
                        conn:Disconnect()
                        if settings.CallOnChange then
                            safecall(settings.Callback, kn)
                        end
                        saveConfig()
                    end
                end)
            end)

            -- Trigger keybind action
            local kbConn = UserInputService.InputBegan:Connect(function(inp, proc)
                if proc or listening then return end
                if settings.CurrentKeybind ~= "None" then
                    local ok, kc = pcall(function() return Enum.KeyCode[settings.CurrentKeybind] end)
                    if ok and inp.KeyCode == kc then
                        if not settings.CallOnChange then
                            safecall(settings.Callback, settings.CurrentKeybind)
                        end
                    end
                end
            end)
            table.insert(keybindConns, kbConn)

            function settings:Set(kb)
                settings.CurrentKeybind = kb
                keyLbl.Text = kb
                if settings.CallOnChange then
                    safecall(settings.Callback, kb)
                end
                saveConfig()
            end

            if settings.Flag and CEnabled then
                ModernUI.Flags[settings.Flag] = settings
            end
            return settings
        end

