                btn.BorderSizePixel = 0
                btn.ZIndex          = 12
                btn.AutoButtonColor = false
                btn.LayoutOrder     = 1
                btn.Parent          = optFrame
                makeRound(btn, 6)
                optBtns[opt] = btn
                totalOptH   += ITEM_H - 1

                local optLbl = Instance.new("TextLabel")
                optLbl.Size              = UDim2.new(1, -28, 1, 0)
                optLbl.Position          = UDim2.new(0, 10, 0, 0)
                optLbl.BackgroundTransparency = 1
                optLbl.Text              = opt
                optLbl.TextColor3        = isSelected
                    and SelectedTheme.Accent
                    or  SelectedTheme.TextSecondary
                optLbl.Font              = Enum.Font.Gotham
                optLbl.TextSize          = 12
                optLbl.TextXAlignment    = Enum.TextXAlignment.Left
                optLbl.ZIndex            = 13
                optLbl.Parent            = btn

                local checkLbl = Instance.new("TextLabel")
                checkLbl.Size              = UDim2.new(0, 18, 1, 0)
                checkLbl.Position          = UDim2.new(1, -22, 0, 0)
                checkLbl.BackgroundTransparency = 1
                checkLbl.Text              = "✓"
                checkLbl.TextColor3        = SelectedTheme.Accent
                checkLbl.Font              = Enum.Font.GothamBold
                checkLbl.TextSize          = 12
                checkLbl.TextTransparency  = isSelected and 0 or 1
                checkLbl.ZIndex            = 13
                checkLbl.Parent            = btn

                btn.MouseEnter:Connect(function()
                    tween(btn, ease(0.15), {BackgroundColor3 = SelectedTheme.SurfaceHover})
                end)
                btn.MouseLeave:Connect(function()
                    local sel = table.find(settings.CurrentOption, opt) ~= nil
                    tween(btn, ease(0.15), {
                        BackgroundColor3 = sel
                            and SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.72)
                            or  SelectedTheme.Surface
                    })
                end)

                btn.MouseButton1Click:Connect(function()
                    if settings.MultipleOptions then
                        local idx = table.find(settings.CurrentOption, opt)
                        if idx then
                            table.remove(settings.CurrentOption, idx)
                            tween(btn, ease(0.2), {BackgroundColor3 = SelectedTheme.Surface})
                            tween(optLbl, ease(0.2), {TextColor3 = SelectedTheme.TextSecondary})
                            tween(checkLbl, ease(0.2), {TextTransparency = 1})
                        else
                            table.insert(settings.CurrentOption, opt)
                            tween(btn, ease(0.2), {BackgroundColor3 = SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.72)})
                            tween(optLbl, ease(0.2), {TextColor3 = SelectedTheme.Accent})
                            tween(checkLbl, ease(0.2), {TextTransparency = 0})
                        end
                    else
                        -- Deselect all
                        for o, b in pairs(optBtns) do
                            tween(b, ease(0.2), {BackgroundColor3 = SelectedTheme.Surface})
                            for _, c in ipairs(b:GetChildren()) do
                                if c:IsA("TextLabel") then
                                    if c.Text == "✓" then
                                        tween(c, ease(0.2), {TextTransparency = 1})
                                    else
                                        tween(c, ease(0.2), {TextColor3 = SelectedTheme.TextSecondary})
                                    end
                                end
                            end
                        end
                        settings.CurrentOption = {opt}
                        tween(btn, ease(0.2), {BackgroundColor3 = SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.72)})
                        tween(optLbl, ease(0.2), {TextColor3 = SelectedTheme.Accent})
                        tween(checkLbl, ease(0.2), {TextTransparency = 0})
                    end

                    refreshLabel()
                    safecall(settings.Callback, settings.CurrentOption)
                    saveConfig()

                    if not settings.MultipleOptions then
                        task.wait(0.08)
                        isOpen = false
                        tween(arrow, ease(0.3), {Rotation = 0})
                        tween(card, spring(0.4), {Size = UDim2.new(1, 0, 0, 52)})
                    end
                end)
            end

            local ghost = Instance.new("TextButton")
            ghost.Size               = UDim2.new(1, 0, 0, 52)
            ghost.BackgroundTransparency = 1
            ghost.Text               = ""
            ghost.ZIndex             = 14
            ghost.Parent             = card

            ghost.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    tween(arrow, ease(0.3), {Rotation = 180})
                    tween(card, spring(0.5), {Size = UDim2.new(1, 0, 0, 52 + totalOptH + 6)})
                else
                    tween(arrow, ease(0.3), {Rotation = 0})
                    tween(card, spring(0.4), {Size = UDim2.new(1, 0, 0, 52)})
                end
            end)

            function settings:Set(opt)
                if type(opt) == "string" then opt = {opt} end
                settings.CurrentOption = opt
                refreshLabel()
                for o, b in pairs(optBtns) do
                    local sel = table.find(settings.CurrentOption, o) ~= nil
                    tween(b, ease(0.2), {
                        BackgroundColor3 = sel
                            and SelectedTheme.Accent:Lerp(SelectedTheme.Surface, 0.72)
                            or  SelectedTheme.Surface
                    })
                    for _, c in ipairs(b:GetChildren()) do
                        if c:IsA("TextLabel") then
                            if c.Text == "✓" then
                                tween(c, ease(0.2), {TextTransparency = sel and 0 or 1})
                            else
                                tween(c, ease(0.2), {TextColor3 = sel and SelectedTheme.Accent or SelectedTheme.TextSecondary})
                            end
                        end
                    end
                end
                safecall(settings.Callback, settings.CurrentOption)
                saveConfig()
            end

            function settings:AddOption(opt)
                if table.find(settings.Options, opt) then return end
                table.insert(settings.Options, opt)
                -- Rebuild would be ideal; for simplicity notify
            end

            if settings.Flag and CEnabled then
                ModernUI.Flags[settings.Flag] = settings
            end
            return settings
        end

