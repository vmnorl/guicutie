                settings.CurrentOption = {settings.CurrentOption}
            end
            settings.CurrentOption = settings.CurrentOption or {}
            settings.Options       = settings.Options or {}

            local ITEM_H = 36
            local isOpen = false
            local card   = makeCard(52, true)
            card.ZIndex           = 10
            card.ClipsDescendants = true

            local nameLbl = Instance.new("TextLabel")
            nameLbl.Size           = UDim2.new(0.48,0,0,52)
