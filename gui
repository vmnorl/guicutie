    lbl.Font               = Enum.Font.Gotham
    lbl.TextSize           = 11
    lbl.ZIndex             = 51
    lbl.Parent             = tip

    -- Auto-size
    task.defer(function()
        local bounds = TextService:GetTextSize(text, 11, Enum.Font.Gotham, Vector2.new(300, 26))
        tip.Size = UDim2.new(0, bounds.X + 16, 0, 26)
    end)

    if parent:IsA("GuiButton") or parent:IsA("Frame") then
        parent.MouseEnter:Connect(function()
            tip.Visible = true
            tween(tip, ease(0.2), {BackgroundTransparency = 0})
        end)
        parent.MouseLeave:Connect(function()
            tip.Visible = false
        end)
    end

    return tip
end

-- ═══════════════════════════════════════════════════════════════
-- DRAGGING SYSTEM (improved)
-- ═══════════════════════════════════════════════════════════════

local function makeDraggable(frame, handle)
    local dragging   = false
    local startPos   = nil
    local startMouse = nil
    local conn1, conn2

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging   = true
            startPos   = frame.Position
            startMouse = UserInputService:GetMouseLocation()
            tween(frame, ease(0.1), {})
        end
    end)

    conn1 = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    conn2 = RunService.Heartbeat:Connect(function()
        if not dragging or Hidden then return end
        local mouse = UserInputService:GetMouseLocation()
        local delta = mouse - startMouse
        -- Clamp to screen
        local vp = workspace.CurrentCamera.ViewportSize
        local newX = math.clamp(startPos.X.Offset + delta.X, 0, vp.X - frame.AbsoluteSize.X)
        local newY = math.clamp(startPos.Y.Offset + delta.Y, 0, vp.Y - frame.AbsoluteSize.Y)
        frame.Position = UDim2.new(startPos.X.Scale, newX, startPos.Y.Scale, newY)
    end)

    frame.Destroying:Connect(function()
        if conn1 then conn1:Disconnect() end
        if conn2 then conn2:Disconnect() end
    end)
end

