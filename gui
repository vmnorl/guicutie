local function tween(obj, info, props)
    local ok, t = pcall(TweenService.Create, TweenService, obj, info, props)
    if ok and t then t:Play() return t end
end

local function spring(t, style, dir)
    return TweenInfo.new(
        t or 0.5,
        style or Enum.EasingStyle.Exponential,
        dir  or Enum.EasingDirection.Out
    )
end

local function ease(t, style, dir)
    return TweenInfo.new(
        t or 0.4,
        style or Enum.EasingStyle.Quint,
        dir  or Enum.EasingDirection.Out
    )
end

local function safecall(f, ...)
    if type(f) ~= "function" then return false end
    local args = {...}
    local ok, err = pcall(function() return f(table.unpack(args)) end)
    if not ok then warn("[ModernUI] Callback error: " .. tostring(err)) end
    return ok
end

local function ensureFolder(path)
    pcall(function()
        if isfolder and not isfolder(path) then
            makefolder(path)
        end
    end)
end

local function colorToHex(c)
    return string.format("#%02X%02X%02X",
        math.floor(c.R * 255),
        math.floor(c.G * 255),
        math.floor(c.B * 255)
    )
end

local function hexToColor(hex)
    hex = hex:gsub("#","")
    if #hex < 6 then return Color3.new(1,1,1) end
    return Color3.fromRGB(
        tonumber(hex:sub(1,2),16) or 255,
        tonumber(hex:sub(3,4),16) or 255,
        tonumber(hex:sub(5,6),16) or 255
    )
end

