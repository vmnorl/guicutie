-- Notification
function ModernUI:Notify(data)
    task.spawn(function()
        local notif = Instance.new("Frame")
        notif.Name = "Notification"
        notif.Size = UDim2.new(1, 0, 0, 0)
        notif.BackgroundColor3 = SelectedTheme.NotifBg
        notif.BackgroundTransparency = 1
        notif.ClipsDescendants = true
        notif.Parent = NotifContainer
        makeRound(notif, 12)
        local stroke = makeStroke(notif, SelectedTheme.NotifBorder, 1, 0)

        -- Accent bar
        local bar = Instance.new("Frame")
        bar.Name = "AccentBar"
        bar.Size = UDim2.new(0, 3, 1, 0)
        bar.Position = UDim2.new(0, 0, 0, 0)
        bar.BackgroundColor3 = data.AccentColor or SelectedTheme.Accent
        bar.BorderSizePixel = 0
        bar.Parent = notif
        makeRound(bar, 4)

        -- Icon
        local icon = Instance.new("ImageLabel")
        icon.Name = "Icon"
        icon.Size = UDim2.new(0, 28, 0, 28)
        icon.Position = UDim2.new(0, 18, 0.5, -14)
        icon.BackgroundTransparency = 1
        icon.Image = data.Image and ("rbxassetid://" .. tostring(data.Image)) or ""
        icon.ImageColor3 = data.AccentColor or SelectedTheme.Accent
        icon.ScaleType = Enum.ScaleType.Fit
        icon.Parent = notif

        -- Title
        local title = Instance.new("TextLabel")
        title.Name = "Title"
        title.Size = UDim2.new(1, -60, 0, 18)
        title.Position = UDim2.new(0, data.Image and 54 or 18, 0, 14)
        title.BackgroundTransparency = 1
        title.Text = data.Title or "Notification"
        title.TextColor3 = SelectedTheme.TextPrimary
        title.TextTransparency = 1
        title.Font = Enum.Font.GothamBold
        title.TextSize = 13
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.Parent = notif

        -- Content
        local content = Instance.new("TextLabel")
        content.Name = "Content"
        content.Size = UDim2.new(1, -60, 0, 0)
        content.Position = UDim2.new(0, data.Image and 54 or 18, 0, 34)
        content.BackgroundTransparency = 1
        content.Text = data.Content or ""
        content.TextColor3 = SelectedTheme.TextSecondary
        content.TextTransparency = 1
        content.Font = Enum.Font.Gotham
        content.TextSize = 12
        content.TextXAlignment = Enum.TextXAlignment.Left
        content.TextWrapped = true
        content.AutomaticSize = Enum.AutomaticSize.Y
        content.Parent = notif

        task.wait()

        -- Calculate height
        local textHeight = content.TextBounds.Y
        local totalHeight = math.max(textHeight + 50, 70)

        -- Animate in
        tween(notif, spring(0.5), {Size = UDim2.new(1, 0, 0, totalHeight), BackgroundTransparency = 0.05})
        task.wait(0.1)
        tween(title, spring(0.4), {TextTransparency = 0})
        tween(content, spring(0.4), {TextTransparency = 0.15})
        tween(stroke, spring(0.4), {Transparency = 0.6})

        local duration = data.Duration or math.clamp(#(data.Content or "") * 0.06 + 3, 3, 10)
        task.wait(duration)

        -- Animate out
        tween(notif, ease(0.4), {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0)})
        tween(title, ease(0.3), {TextTransparency = 1})
        tween(content, ease(0.3), {TextTransparency = 1})
        tween(stroke, ease(0.3), {Transparency = 1})
        task.wait(0.5)
        notif:Destroy()
    end)
end

-- Configuration
local function saveConfig()
    if not CEnabled or not globalLoaded then return end
    local data = {}
    for flag, element in pairs(ModernUI.Flags) do
        if element.Type == "ColorPicker" then
            local c = element.Color
            data[flag] = {R = c.R * 255, G = c.G * 255, B = c.B * 255}
        elseif element.Type == "Toggle" then
            data[flag] = element.CurrentValue
        elseif element.Type == "Slider" then
            data[flag] = element.CurrentValue
        elseif element.Type == "Dropdown" then
            data[flag] = element.CurrentOption
        elseif element.Type == "Keybind" then
            data[flag] = element.CurrentKeybind
        elseif element.Type == "Input" then
            data[flag] = element.CurrentValue
        end
    end
    pcall(writefile, ConfigFolder .. "/" .. CFileName .. ConfigExt, HttpService:JSONEncode(data))
end

local function loadConfig()
    if not CEnabled then return end
    if not isfile or not isfile(ConfigFolder .. "/" .. CFileName .. ConfigExt) then return end
    local raw = readfile(ConfigFolder .. "/" .. CFileName .. ConfigExt)
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok then return end
    for flag, value in pairs(data) do
        local el = ModernUI.Flags[flag]
        if el and el.Set then
            task.spawn(function()
                if el.Type == "ColorPicker" then
                    el:Set(Color3.fromRGB(value.R, value.G, value.B))
                else
                    el:Set(value)
                end
            end)
        end
    end
end

-- Dragging
local function makeDraggable(frame, handle)
    local dragging = false
    local startPos, startMouse

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            startPos = frame.Position
            startMouse = UserInputService:GetMouseLocation()
        end
    end)

    local conn1 = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    local conn2 = RunService.RenderStepped:Connect(function()
        if dragging and not Hidden then
            local delta = UserInputService:GetMouseLocation() - startMouse
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    frame.Destroying:Connect(function()
        conn1:Disconnect()
        conn2:Disconnect()
    end)
end

