        -- PROGRESS BAR
        -- ══════════════════════════════════════════════════════
        function Tab:CreateProgressBar(settings)
            settings = settings or {}
            local card = makeCard(60)

            local nameLbl = Instance.new("TextLabel")
            nameLbl.Size             = UDim2.new(0.7, 0, 0, 20)
            nameLbl.Position         = UDim2.new(0, 14, 0, 8)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text             = settings.Name or "Progress"
            nameLbl.TextColor3       = SelectedTheme.TextPrimary
            nameLbl.Font             = Enum.Font.GothamSemibold
            nameLbl.TextSize         = 13
            nameLbl.TextXAlignment   = Enum.TextXAlignment.Left
            nameLbl.Parent           = card

            local pctLbl = Instance.new("TextLabel")
            pctLbl.Size              = UDim2.new(0.3, -14, 0, 20)
            pctLbl.Position          = UDim2.new(0.7, 0, 0, 8)
            pctLbl.BackgroundTransparency = 1
            pctLbl.TextColor3        = SelectedTheme.Accent
            pctLbl.Font              = Enum.Font.GothamBold
            pctLbl.TextSize          = 13
            pctLbl.TextXAlignment    = Enum.TextXAlignment.Right
            pctLbl.Parent            = card

            local trackBg = Instance.new("Frame")
            trackBg.Size            = UDim2.new(1, -28, 0, 8)
            trackBg.Position        = UDim2.new(0, 14, 0, 38)
            trackBg.BackgroundColor3 = SelectedTheme.SliderTrack
            trackBg.BorderSizePixel = 0
            trackBg.ZIndex          = 4
            trackBg.Parent          = card
            makeRound(trackBg, 4)

            local curPct = math.clamp((settings.CurrentValue or 0) / 100, 0, 1)

            local trackFill = Instance.new("Frame")
            trackFill.Size            = UDim2.new(curPct, 0, 1, 0)
            trackFill.BackgroundColor3 = settings.FillColor or SelectedTheme.SliderFill
            trackFill.BorderSizePixel = 0
            trackFill.ZIndex          = 5
            trackFill.Parent          = trackBg
            makeRound(trackFill, 4)

            -- Shimmer effect
            local shimmer = Instance.new("Frame")
            shimmer.Size               = UDim2.new(0, 60, 1, 0)
            shimmer.Position           = UDim2.new(-0.5, 0, 0, 0)
            shimmer.BackgroundColor3   = Color3.fromRGB(255,255,255)
            shimmer.BackgroundTransparency = 0.8
            shimmer.BorderSizePixel    = 0
            shimmer.ZIndex             = 6
            shimmer.ClipsDescendants   = false
            shimmer.Parent             = trackFill
            makeRound(shimmer, 4)

            -- Animate shimmer
            task.spawn(function()
                while card.Parent do
                    tween(shimmer, TweenInfo.new(1.5, Enum.EasingStyle.Linear), {
                        Position = UDim2.new(1.2, 0, 0, 0)
                    })
                    task.wait(2)
                    shimmer.Position = UDim2.new(-0.5, 0, 0, 0)
                end
            end)

            pctLbl.Text = tostring(math.floor(curPct * 100)) .. "%"

            local PrgObj = {}
            function PrgObj:Set(pct)
                pct = math.clamp(pct, 0, 100)
                local p = pct / 100
                tween(trackFill, spring(0.5), {Size = UDim2.new(p, 0, 1, 0)})
                pctLbl.Text = tostring(math.floor(pct)) .. "%"
            end
            function PrgObj:SetColor(col)
                tween(trackFill, ease(0.3), {BackgroundColor3 = col})
            end
            return PrgObj
        end

