local function saveConfig()
    if not CEnabled or not globalLoaded then return end
    local data = {}
    for flag, el in pairs(ModernUI.Flags) do
        if el.Type == "Toggle"      then data[flag] = el.CurrentValue
        elseif el.Type == "Slider"  then data[flag] = el.CurrentValue
        elseif el.Type == "Dropdown"then data[flag] = el.CurrentOption
        elseif el.Type == "Keybind" then data[flag] = el.CurrentKeybind
        elseif el.Type == "Input"   then data[flag] = el.CurrentValue
        elseif el.Type == "ColorPicker" then
            local c = el.CurrentColor
            if c then data[flag] = {R=math.floor(c.R*255),G=math.floor(c.G*255),B=math.floor(c.B*255)} end
        end
    end
    
    -- Save UI toggle keybind
    data["__UIToggleKeybind"] = openKeybind
    
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then
        pcall(writefile, ConfigFolder.."/"..CFileName..ConfigExt, encoded)
    end
end

local function loadConfig()
    if not CEnabled then return end
    local path = ConfigFolder.."/"..CFileName..ConfigExt
    if not (isfile and isfile(path)) then return end
    local raw = readfile(path)
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok or type(data) ~= "table" then return end
    
    -- Load UI toggle keybind
    if data["__UIToggleKeybind"] then
        openKeybind = data["__UIToggleKeybind"]
    end
    
    for flag, value in pairs(data) do
        if flag ~= "__UIToggleKeybind" then
            local el = ModernUI.Flags[flag]
            if el and el.Set then
                task.spawn(function()
                    pcall(function()
                        if el.Type == "ColorPicker" then
                            el:Set(Color3.fromRGB(value.R, value.G, value.B))
                        else
                            el:Set(value)
                        end
                    end)
                end)
            end
        end
    end
end

